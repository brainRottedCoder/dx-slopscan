{
  "name": "@slop-scanner/detection",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bakeoff/bakeoff-runner": {
      "types": "./dist/bakeoff/bakeoff-runner.d.ts",
