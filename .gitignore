# =============================================================================
# DX SlopScan / Hugo — do not commit secrets, caches, or reproducible artifacts
# =============================================================================

# --- Secrets & local env (copy from *.example) ---
.env
.env.*
!.env.example
!**/.env.example
!frontend/.env.local.example
backend/.env
frontend/.env.local
frontend/.env*.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
venv/
ENV/
env/

# pytest / coverage / type checkers
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# Jupyter
.ipynb_checkpoints/

# --- Node.js (frontend, cli) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Next.js
frontend/.next/
frontend/out/*
!frontend/out/.gitkeep

# TypeScript build info (regenerated)
*.tsbuildinfo

# --- OS & editors ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# VS Code — keep shared settings if you add them; ignore personal/local
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# Cursor / local agent artifacts
.cursor/
*.cursorrules.local

# --- Docker ---
.docker/

# --- ML model caches (downloaded at runtime / Docker build) ---
.cache/
huggingface/
sentence_transformers/

# --- Logs & temp ---
*.log
backend*.log
frontend*.log
frontend/dev.log
logs/
tmp/
temp/
*.tmp
*.bak
push.ps1

# --- Repomix / codebase dumps (local analysis only) ---
repomix-output*.xml
repomix-output*/

# --- Agent / one-off planning docs (not part of the app) ---
frontend/FRONTEND_COMPLETE_DOCUMENTATION.md
frontend/THEME_TRANSFORMATION_PLAN.md

# --- Misc local tooling ---
.vercel
.railway
*.local

# GitHub Actions local composite caches (if any)
.github/actions/**/__pycache__/
