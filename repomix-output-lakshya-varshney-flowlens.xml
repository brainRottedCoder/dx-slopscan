<file path="frontend/index.html">
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FlowLens — Developer Flow Intelligence</title>

  <!-- Tailwind CSS CDN -->
