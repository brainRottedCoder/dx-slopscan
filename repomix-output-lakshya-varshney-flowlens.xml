);
"""

_CREATE_INGESTION_RUNS = """
CREATE TABLE IF NOT EXISTS ingestion_runs (
    id               INTEGER PRIMARY KEY AUTOINCREMENT,
    repo_url         TEXT NOT NULL,
    repo_name        TEXT,
    since_date       TEXT,
    commits_ingested INTEGER DEFAULT 0,
