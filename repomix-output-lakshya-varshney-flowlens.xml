  <!-- ═══════════════════════════════════
       JAVASCRIPT
  ═══════════════════════════════════ -->
  <script>
  'use strict';

  /* ── Config ── */
  const API_BASE      = '';          // same origin
  const POLL_INTERVAL = 1200;        // ms between status polls
  const DASHBOARD_URL = '/dashboard';

  /* ── State ── */
  let pollTimer   = null;
  let loggedSteps = new Set();

  /* ── Step definitions — shown as log lines during ingestion ──
     Each step maps to a `step` string returned by /api/ingestion-status.
     The frontend shows them in order regardless of exact timing.        */
  const STEPS = [
    {
      step:    'cloning',
      pct:     8,
      badge:   'info',
      text:    () => `<span class="dim">git clone --depth=full</span> <span class="hl">${getRepoShort()}</span>`,
    },
    {
      step:    'ingesting',
      pct:     22,
      badge:   'info',
      text:    () => `Ingesting commit history <span class="dim">· GitPython parser active</span>`,
    },
    {
      step:    'features',
      pct:     45,
      badge:   'info',
      text:    () => `Engineering <span class="amb">14 developer-flow features</span> per day`,
    },
    {
      step:    'scaling',
      pct:     58,
      badge:   'info',
      text:    () => `StandardScaler fit <span class="dim">· zero mean · unit variance</span>`,
    },
    {
      step:    'training',
      pct:     72,
      badge:   'ml',
      text:    () => `Training <span class="purp">IsolationForest</span> <span class="dim">n_estimators=200 contamination=0.1</span>`,
    },
    {
      step:    'shap',
      pct:     84,
      badge:   'ml',
      text:    () => `Computing <span class="purp">SHAP</span> values <span class="dim">· TreeExplainer · top-5 features per anomaly</span>`,
    },
    {
      step:    'insights',
      pct:     93,
      badge:   'ml',
      text:    () => `Generating rule-based recommendations <span class="dim">· LLM synthesis queued</span>`,
    },
    {
      step:    'saving',
      pct:     98,
      badge:   'ok',
      text:    () => `Writing results to <span class="grn">flowlens.db</span> <span class="dim">· SQLite · 4 tables</span>`,
    },
    {
      step:    'ready',
      pct:     100,
      badge:   'ok',
      text:    () => `<span class="grn">✓ FlowLens ready</span> <span class="dim">· Dashboard available at</span> <span class="hl">localhost:5000/dashboard</span>`,
    },
  ];

  /* ── Repo short name for display ── */
  function getRepoShort() {
    const val = document.getElementById('repo-url').value.trim();
    try {
      const url = new URL(val);
      return url.pathname.replace(/^\//, '').replace(/\.git$/, '');
    } catch {
      return val.split('/').slice(-2).join('/') || val;
    }
  }

  /* ── Timestamp string ── */
  function nowTime() {
    return new Date().toLocaleTimeString('en', { hour12: false });
  }

  /* ── Validate repo URL / path ── */
  function validateRepo(val) {
    if (!val) return 'Please enter a GitHub URL or local path.';
    const isGithub = /^https?:\/\/(www\.)?github\.com\/.+\/.+/.test(val);
    const isLocal  = val.startsWith('/') || val.startsWith('./') || val.startsWith('~');
    if (!isGithub && !isLocal) {
      return 'Must be a GitHub URL (https://github.com/owner/repo) or a local path.';
    }
    return null;
  }

  /* ── Append a log line to the terminal ── */
  function appendLog(badge, textHTML, timestamp) {
    const body = document.getElementById('terminal-body');

    const line = document.createElement('div');
    line.className = 'log-line';
    line.innerHTML = `
      <span class="log-time">${timestamp || nowTime()}</span>
      <span class="log-badge ${badge}">${badge.toUpperCase()}</span>
      <span class="log-text">${textHTML}</span>
    `;
    body.appendChild(line);

    // Trigger animation on next frame
    requestAnimationFrame(() => {
      requestAnimationFrame(() => line.classList.add('visible'));
    });

    // Auto-scroll terminal body
    body.scrollTop = body.scrollHeight;
  }

  /* ── Update progress bar ── */
  function setProgress(pct, label) {
    document.getElementById('progress-fill').style.width = pct + '%';
    document.getElementById('progress-pct').textContent = pct + '%';
    if (label) document.getElementById('progress-label-text').textContent = label;
  }

  /* ── START SCAN — called by button ── */
  async function startScan() {
    const input  = document.getElementById('repo-url');
    const errEl  = document.getElementById('input-error');
    const repoUrl = input.value.trim();

    // Validate
    const validationError = validateRepo(repoUrl);
    if (validationError) {
      errEl.textContent = validationError;
      errEl.style.display = 'block';
      document.getElementById('input-box').style.borderColor = 'var(--danger)';
      return;
    }

    errEl.style.display = 'none';
    document.getElementById('input-box').style.borderColor = '';

    // Disable button
    const btn = document.getElementById('scan-btn');
    btn.disabled = true;
    btn.textContent = '⏳ Starting…';

    // Show overlay
    document.getElementById('scan-repo-label').textContent = getRepoShort();
    showOverlay();

    // Fire POST /api/ingest
    try {
      const res = await fetch(`${API_BASE}/api/ingest`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ repo_url: repoUrl }),
      });

      const json = await res.json();

      if (!res.ok || !json.ok) {
        showError(json.error || `HTTP ${res.status} — could not start ingestion.`);
        return;
      }

      // Start polling
      appendLog('info', `Ingestion job started <span class="dim">· job_id: <span class="hl">${json.data?.job_id || 'pending'}</span></span>`);
      startPolling();

    } catch (err) {
      showError(`Could not reach the FlowLens server. Is run.py running? (${err.message})`);
    }
  }

  /* ── Show scanning overlay ── */
  function showOverlay() {
    document.getElementById('scan-overlay').classList.add('active');
    document.getElementById('terminal-body').innerHTML = '';
    document.getElementById('success-banner').style.display = 'none';
    document.getElementById('error-banner').style.display = 'none';
    loggedSteps.clear();
    setProgress(0, 'Starting ingestion…');

    appendLog('info', `FlowLens ingestion pipeline <span class="dim">initialising…</span>`);
  }

  /* ── Poll /api/ingestion-status ── */
  function startPolling() {
    if (pollTimer) clearInterval(pollTimer);
    pollTimer = setInterval(pollStatus, POLL_INTERVAL);
  }

  function stopPolling() {
    if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
  }

  async function pollStatus() {
    try {
      const res  = await fetch(`${API_BASE}/api/ingestion-status`);
      const json = await res.json();

      if (!json.ok) {
        stopPolling();
        showError(json.error || 'Ingestion failed.');
        return;
      }

      const d = json.data;
      handleStatusUpdate(d);

    } catch (err) {
      // Network blip — keep polling, don't abort
      console.warn('Poll error:', err.message);
    }
  }

  /* ── Handle a status payload from the server ── */
  function handleStatusUpdate(d) {
    const step     = d.step || '';       // e.g. "training"
    const pct      = d.percent || 0;     // 0–100 integer
    const message  = d.message || '';    // free-form server message
    const status   = d.status;           // "in_progress" | "complete" | "error"
    const ts       = d.timestamp || nowTime();

    // Show any server-provided log message that we haven't shown yet
    if (message && !loggedSteps.has('msg:' + message)) {
      loggedSteps.add('msg:' + message);
      appendLog('info', escapeHTML(message), ts);
    }

    // Walk through our ordered STEPS and show any that match or precede current pct
    STEPS.forEach(s => {
      if (!loggedSteps.has(s.step) && pct >= s.pct - 5) {
        loggedSteps.add(s.step);
        appendLog(s.badge, s.text(), ts);
        setProgress(s.pct, stepLabel(s.step));
      }
    });

    // Override with server-reported pct if higher
    const fill = document.getElementById('progress-fill');
    const serverPct = parseInt(fill.style.width) || 0;
    if (pct > serverPct) setProgress(pct, stepLabel(step));

    // Terminal states
    if (status === 'complete') {
      stopPolling();
      setProgress(100, 'Analysis complete');

      // Make sure all steps shown
      STEPS.forEach(s => {
        if (!loggedSteps.has(s.step)) {
          loggedSteps.add(s.step);
          appendLog(s.badge, s.text(), ts);
        }
      });

      // Show commit / developer counts if provided
      if (d.commits_ingested || d.developer_count) {
        const info = [
          d.commits_ingested && `<span class="hl">${d.commits_ingested.toLocaleString()}</span> commits`,
          d.developer_count  && `<span class="hl">${d.developer_count}</span> developers`,
          d.developer_days   && `<span class="hl">${d.developer_days.toLocaleString()}</span> developer-days`,
        ].filter(Boolean).join(' · ');
        appendLog('ok', `Indexed ${info}`, ts);
      }

      showSuccess(d);

    } else if (status === 'error') {
      stopPolling();
      showError(d.error || 'Ingestion failed. Check the server logs.');
    }
  }

  /* ── Show success banner ── */
  function showSuccess(d) {
    const banner = document.getElementById('success-banner');
    const sub    = document.getElementById('success-sub');

    const parts = [];
    if (d.commits_ingested) parts.push(`${d.commits_ingested.toLocaleString()} commits`);
    if (d.developer_count)  parts.push(`${d.developer_count} developers`);
    if (d.developer_days)   parts.push(`${d.developer_days.toLocaleString()} developer-days analysed`);

    sub.textContent = parts.length
      ? parts.join(' · ') + ' · Model trained and ready.'
      : 'Repository analysed. Model trained and ready.';

    banner.style.display = 'block';

    // Auto-redirect after 2.5 seconds
    setTimeout(() => {
      window.location.href = DASHBOARD_URL;
    }, 2500);
  }

  /* ── Show error banner ── */
  function showError(msg) {
    appendLog('warn', `<span style="color:var(--danger)">Error:</span> ${escapeHTML(msg)}`);
    setProgress(0, 'Ingestion failed');

    const banner = document.getElementById('error-banner');
    document.getElementById('error-msg').textContent = msg;
    banner.style.display = 'block';
  }

  /* ── Reset back to home ── */
  function resetToHome() {
    stopPolling();
    document.getElementById('scan-overlay').classList.remove('active');
    document.getElementById('scan-btn').disabled = false;
    document.getElementById('scan-btn').textContent = '⚡ Scan Repo';
  }

  /* ── Step → human label ── */
  function stepLabel(step) {
    const map = {
      cloning:   'Cloning repository…',
      ingesting: 'Ingesting commits…',
      features:  'Engineering features…',
      scaling:   'Preprocessing data…',
      training:  'Training ML model…',
      shap:      'Computing SHAP values…',
      insights:  'Generating insights…',
      saving:    'Saving to database…',
      ready:     'Analysis complete',
    };
    return map[step] || step || 'Working…';
  }

  /* ── HTML escape for server messages ── */
  function escapeHTML(str) {
    const d = document.createElement('div');
    d.textContent = str;
    return d.innerHTML;
  }

  /* ── Enter key on input ── */
  document.getElementById('repo-url').addEventListener('keydown', e => {
    if (e.key === 'Enter') startScan();
  });

  /* ── If status is already "complete" on load (re-run scenario), ──
     show a "Go to dashboard" link immediately.                       */
  window.addEventListener('DOMContentLoaded', async () => {
    try {
      const res  = await fetch(`${API_BASE}/api/status`);
      const json = await res.json();
      if (json.ok && json.data?.status === 'ready') {
        const hint = document.querySelector('.input-hints');
        if (hint) {
          hint.insertAdjacentHTML('beforeend', `
            <span class="hint-item" style="margin-left:auto;">
              <a href="${DASHBOARD_URL}"
                 style="color:var(--accent);text-decoration:none;font-weight:700;">
                ▶ Dashboard already loaded — open →
              </a>
            </span>
          `);
        }
      }
    } catch { /* server not up yet — fine */ }
  });
  </script>

</body>
</html>
