    </footer>

  </div><!-- /#main-page -->


  <!-- ═══════════════════════════════════
       SCANNING OVERLAY
  ═══════════════════════════════════ -->
  <div id="scan-overlay">

    <div class="scan-header">
      <h2>Scanning repository</h2>
      <p>Analysing <span class="repo-name" id="scan-repo-label">…</span></p>
    </div>

    <!-- Terminal window -->
    <div class="terminal">
      <div class="terminal-bar">
        <div class="t-dot red"></div>
        <div class="t-dot amber"></div>
        <div class="t-dot green"></div>
        <span class="terminal-title">flowlens — ingestion pipeline</span>
      </div>
      <div class="terminal-body" id="terminal-body">
        <!-- Log lines injected by JS -->
      </div>
      <div class="progress-wrap">
        <div class="progress-label">
          <span id="progress-label-text">Initialising…</span>
          <span id="progress-pct">0%</span>
