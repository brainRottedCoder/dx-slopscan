# FlowLens Configuration
model:
  n_estimators: 200
  contamination: 0.1       # Fraction of expected anomalous days
  random_state: 42

features:
  min_commits_per_day: 2   # Developer-days with fewer commits are dropped
  min_days_per_developer: 5  # Developers with fewer days are excluded from analysis

scoring:
  flow_score_min: 0
  flow_score_max: 100
  hours_per_flow_point: 0.5  # 1 point = 0.5 dev-hours/week recovered

ingestion:
  default_days_lookback: 90
  batch_size: 5000           # Commits per GitPython batch
  clone_depth: 500 

llm:
  model: "gemini-2.5-flash"
  max_tokens: 300
  cache_enabled: true

server:
  host: "0.0.0.0"
  port: 5000
  debug: false
  auto_open_browser: true
