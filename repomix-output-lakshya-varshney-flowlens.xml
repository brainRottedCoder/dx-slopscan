<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>FlowLens — Developer Flow Intelligence</title>
  <style>
    /* ═══════════════════════════════════════════════════
       DESIGN TOKENS
    ═══════════════════════════════════════════════════ */
    :root {
      --bg:       #07080b;
      --surface:  #0d0f16;
      --surface2: #12151e;
      --border:   #1a1e2e;
      --accent:   #00e5ff;
      --accent2:  #7c3aed;
      --accent3:  #f59e0b;
      --accent4:  #10b981;
      --danger:   #ef4444;
      --text:     #e8eaf0;
      --muted:    #6b7280;
      --font:     'Courier New', 'Consolas', 'Cascadia Code', monospace;
    }

    /* ═══════════════════════════════════════════════════
       BASE
    ═══════════════════════════════════════════════════ */
    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      font-size: 13px;
      min-height: 100vh;
      overflow-x: hidden;
      position: relative;
    }

    /* ═══════════════════════════════════════════════════
       BACKGROUND — grid + radial glow
    ═══════════════════════════════════════════════════ */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
      background-size: 48px 48px;
      pointer-events: none;
      z-index: 0;
    }

    body::after {
      content: '';
      position: fixed;
      top: -30vh;
      left: 50%;
      transform: translateX(-50%);
      width: 900px;
      height: 600px;
      background: radial-gradient(ellipse at 50% 20%, rgba(0,229,255,0.07) 0%, transparent 60%);
      pointer-events: none;
      z-index: 0;
    }

    /* Scan line */
    .scan-line {
      position: fixed;
      left: 0; width: 100%; height: 1px;
      background: linear-gradient(90deg, transparent, var(--accent), transparent);
      animation: scan 7s linear infinite;
      opacity: 0.5;
      z-index: 1;
      pointer-events: none;
    }
    @keyframes scan {
      0%   { top: -2px; }
      100% { top: 100vh; }
    }

    /* ═══════════════════════════════════════════════════
       LAYOUT WRAPPER
    ═══════════════════════════════════════════════════ */
    .page {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    /* ═══════════════════════════════════════════════════
       NAV
    ═══════════════════════════════════════════════════ */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 20px 48px;
      border-bottom: 1px solid var(--border);
      background: rgba(7,8,11,0.8);
      backdrop-filter: blur(8px);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .nav-logo {
      font-size: 18px;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: #fff;
    }
    .nav-logo span { color: var(--accent); }

    .nav-pills {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .pill {
      font-size: 10px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      padding: 4px 12px;
      border-radius: 2px;
      font-weight: 600;
    }

    .pill-cyan   { background: rgba(0,229,255,0.08);  color: var(--accent);  border: 1px solid rgba(0,229,255,0.2); }
    .pill-purple { background: rgba(124,58,237,0.08); color: #a78bfa;        border: 1px solid rgba(124,58,237,0.2); }
    .pill-green  { background: rgba(16,185,129,0.08); color: var(--accent4); border: 1px solid rgba(16,185,129,0.2); }

    /* ═══════════════════════════════════════════════════
       HERO
    ═══════════════════════════════════════════════════ */
    .hero {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 80px 24px 60px;
      text-align: center;
    }

    /* Track label */
    .track-label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-size: 10px;
      letter-spacing: 0.25em;
      text-transform: uppercase;
      color: var(--accent);
      border: 1px solid rgba(0,229,255,0.25);
      padding: 6px 16px;
      border-radius: 2px;
      margin-bottom: 32px;
      animation: fadeDown 0.6s ease both;
    }

    .track-dot {
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent);
      animation: pulseDot 2s ease-in-out infinite;
    }

    @keyframes pulseDot {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0.3; }
    }

    /* Main headline */
    .headline {
      font-size: clamp(48px, 8vw, 96px);
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 0.95;
      color: #fff;
      margin-bottom: 8px;
      animation: fadeDown 0.7s 0.1s ease both;
    }

    .headline .hl {
      color: var(--accent);
      position: relative;
      display: inline-block;
    }

    /* Glitch underline */
    .headline .hl::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0; right: 0;
      height: 2px;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 1px;
      animation: glitchLine 4s ease-in-out infinite;
    }

    @keyframes glitchLine {
      0%, 90%, 100% { opacity: 1; transform: scaleX(1); }
      92%           { opacity: 0.3; transform: scaleX(0.8) translateX(4px); }
      94%           { opacity: 1; transform: scaleX(1); }
      96%           { opacity: 0.5; transform: scaleX(0.95) translateX(-2px); }
    }

    /* Subheadline */
    .sub-headline {
      font-size: clamp(13px, 2vw, 16px);
      color: var(--muted);
      max-width: 580px;
      line-height: 1.7;
      margin-top: 24px;
      margin-bottom: 48px;
      animation: fadeDown 0.7s 0.2s ease both;
    }

    .sub-headline strong { color: var(--text); font-weight: 600; }

    /* ═══════════════════════════════════════════════════
       REPO INPUT CARD
    ═══════════════════════════════════════════════════ */
    .input-card {
      width: 100%;
      max-width: 620px;
      animation: fadeDown 0.7s 0.3s ease both;
    }

    .input-box {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 6px 6px 6px 20px;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: border-color 0.2s, box-shadow 0.2s;
      position: relative;
      overflow: hidden;
    }

    .input-box::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(0,229,255,0.3), transparent);
    }

    .input-box:focus-within {
      border-color: var(--accent);
      box-shadow: 0 0 0 3px rgba(0,229,255,0.08), 0 0 24px rgba(0,229,255,0.06);
    }

    .input-prefix {
      font-size: 13px;
      color: var(--muted);
      white-space: nowrap;
      flex-shrink: 0;
      user-select: none;
    }

    .repo-input {
      flex: 1;
      background: transparent;
      border: none;
      color: var(--text);
      font-family: var(--font);
      font-size: 13px;
      outline: none;
      padding: 10px 0;
      min-width: 0;
    }

    .repo-input::placeholder { color: #374151; }

    .repo-input::-webkit-input-placeholder { color: #374151; }

    .scan-btn {
      background: var(--accent);
      color: #000;
      border: none;
      border-radius: 3px;
      font-family: var(--font);
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      padding: 10px 20px;
      cursor: pointer;
      flex-shrink: 0;
      transition: opacity 0.15s, transform 0.1s;
      white-space: nowrap;
    }

    .scan-btn:hover:not(:disabled) { opacity: 0.88; transform: translateY(-1px); }
    .scan-btn:active { transform: translateY(0); }
    .scan-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

    /* Input hint row */
    .input-hints {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-top: 10px;
      flex-wrap: wrap;
    }

    .hint-item {
      font-size: 10px;
      color: #374151;
      display: flex;
      align-items: center;
      gap: 5px;
    }

    .hint-item.ok { color: var(--accent4); }

    /* Error message */
    .input-error {
      font-size: 11px;
      color: var(--danger);
      margin-top: 8px;
      display: none;
      padding-left: 4px;
    }

    /* ═══════════════════════════════════════════════════
       STATS ROW (below input)
    ═══════════════════════════════════════════════════ */
    .stats-row {
      display: flex;
      gap: 40px;
      margin-top: 52px;
      animation: fadeDown 0.7s 0.4s ease both;
    }

    .stat-item {
      text-align: center;
    }

    .stat-num {
      font-size: 28px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .stat-num .unit { font-size: 14px; color: var(--muted); }

    .stat-name {
      font-size: 10px;
      color: var(--muted);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-top: 4px;
    }

    .stat-divider {
      width: 1px;
      background: var(--border);
      align-self: stretch;
    }

    /* ═══════════════════════════════════════════════════
       FEATURE PILLS ROW
    ═══════════════════════════════════════════════════ */
    .features-row {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 52px;
      animation: fadeDown 0.7s 0.5s ease both;
    }

    .feature-pill {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 11px;
      color: var(--muted);
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 2px;
      padding: 7px 14px;
    }

    .feature-pill .icon { font-size: 13px; }

    /* ═══════════════════════════════════════════════════
       SCANNING OVERLAY — shown after submit
    ═══════════════════════════════════════════════════ */
    #scan-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: var(--bg);
      z-index: 100;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }

    #scan-overlay.active { display: flex; }

    /* Terminal window */
    .terminal {
      width: 100%;
      max-width: 640px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 4px;
      overflow: hidden;
      box-shadow: 0 32px 80px rgba(0,0,0,0.6);
    }

    .terminal-bar {
      display: flex;
      align-items: center;
      gap: 6px;
      padding: 10px 14px;
      background: var(--surface2);
      border-bottom: 1px solid var(--border);
    }

    .t-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
    }
    .t-dot.red    { background: #ef4444; }
    .t-dot.amber  { background: #f59e0b; }
    .t-dot.green  { background: #10b981; }

    .terminal-title {
      font-size: 11px;
      color: var(--muted);
      margin-left: 8px;
      letter-spacing: 0.05em;
    }

    .terminal-body {
      padding: 20px 24px;
      font-size: 12px;
      line-height: 1.9;
      min-height: 240px;
    }

    /* Log lines */
    .log-line {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      opacity: 0;
      transform: translateY(4px);
      transition: opacity 0.3s ease, transform 0.3s ease;
    }

    .log-line.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .log-time {
      color: #374151;
      flex-shrink: 0;
      font-size: 10px;
      margin-top: 1px;
      width: 64px;
    }

    .log-badge {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.1em;
      padding: 1px 6px;
      border-radius: 2px;
      flex-shrink: 0;
      margin-top: 1px;
    }

    .log-badge.info  { background: rgba(0,229,255,0.1);  color: var(--accent);  border: 1px solid rgba(0,229,255,0.2); }
    .log-badge.ok    { background: rgba(16,185,129,0.1); color: var(--accent4); border: 1px solid rgba(16,185,129,0.2); }
    .log-badge.warn  { background: rgba(245,158,11,0.1); color: var(--accent3); border: 1px solid rgba(245,158,11,0.2); }
    .log-badge.ml    { background: rgba(124,58,237,0.1); color: #a78bfa;        border: 1px solid rgba(124,58,237,0.2); }

    .log-text { color: var(--text); }
    .log-text .dim  { color: var(--muted); }
    .log-text .hl   { color: var(--accent); }
    .log-text .grn  { color: var(--accent4); }
    .log-text .amb  { color: var(--accent3); }
    .log-text .purp { color: #a78bfa; }

    /* Cursor blink */
    .cursor {
      display: inline-block;
      width: 8px; height: 14px;
      background: var(--accent);
      animation: blink 1s step-end infinite;
      vertical-align: text-bottom;
      margin-left: 4px;
    }
    @keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }

    /* Progress bar */
    .progress-wrap {
      margin-top: 16px;
      padding: 0 24px 20px;
    }

    .progress-label {
      display: flex;
      justify-content: space-between;
      font-size: 10px;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .progress-track {
      height: 4px;
      background: var(--border);
      border-radius: 2px;
      overflow: hidden;
    }

    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), var(--accent2));
      border-radius: 2px;
      width: 0%;
      transition: width 0.5s ease;
    }

    /* Scanning label above terminal */
    .scan-header {
      text-align: center;
      margin-bottom: 32px;
    }

    .scan-header h2 {
      font-size: 22px;
      font-weight: 800;
      color: #fff;
      letter-spacing: -0.02em;
      margin-bottom: 4px;
    }

    .scan-header p {
      font-size: 12px;
      color: var(--muted);
    }

    .scan-header .repo-name {
      color: var(--accent);
      font-weight: 700;
    }

    /* Success banner */
    #success-banner {
      display: none;
      margin-top: 20px;
      background: rgba(16,185,129,0.08);
      border: 1px solid rgba(16,185,129,0.3);
      border-radius: 4px;
      padding: 16px 24px;
      text-align: center;
      width: 100%;
      max-width: 640px;
    }

    #success-banner h3 {
      font-size: 15px;
      font-weight: 800;
      color: var(--accent4);
      margin-bottom: 4px;
    }

    #success-banner p {
      font-size: 12px;
      color: var(--muted);
    }

    .redirect-btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 16px;
      background: var(--accent4);
      color: #000;
      border: none;
      border-radius: 3px;
      font-family: var(--font);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: 0.05em;
      padding: 11px 24px;
      cursor: pointer;
      text-decoration: none;
      transition: opacity 0.15s;
    }

    .redirect-btn:hover { opacity: 0.88; }

    /* Error banner */
    #error-banner {
      display: none;
      margin-top: 20px;
      background: rgba(239,68,68,0.07);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 4px;
      padding: 16px 24px;
      text-align: center;
      width: 100%;
      max-width: 640px;
    }

    #error-banner h3 {
      font-size: 14px;
      font-weight: 700;
      color: var(--danger);
      margin-bottom: 4px;
    }

    #error-banner p {
      font-size: 12px;
      color: var(--muted);
      margin-bottom: 12px;
    }

    .retry-btn {
      background: var(--danger);
      color: #fff;
      border: none;
      border-radius: 3px;
      font-family: var(--font);
      font-size: 12px;
      font-weight: 700;
      padding: 8px 18px;
      cursor: pointer;
    }

    /* ═══════════════════════════════════════════════════
       FOOTER
    ═══════════════════════════════════════════════════ */
    footer {
      padding: 20px 48px;
      border-top: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      font-size: 10px;
      color: #374151;
    }

    /* ═══════════════════════════════════════════════════
       ANIMATIONS
    ═══════════════════════════════════════════════════ */
    @keyframes fadeDown {
      from { opacity: 0; transform: translateY(-12px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ═══════════════════════════════════════════════════
       RESPONSIVE
    ═══════════════════════════════════════════════════ */
    @media (max-width: 600px) {
      nav { padding: 16px 20px; }
      .hero { padding: 48px 20px 40px; }
      .stats-row { gap: 24px; }
      footer { flex-direction: column; gap: 8px; text-align: center; }
    }
  </style>
</head>
<body>

  <!-- Scan line -->
  <div class="scan-line"></div>

  <!-- ═══════════════════════════════════
       MAIN PAGE
  ═══════════════════════════════════ -->
  <div class="page" id="main-page">

    <!-- Nav -->
    <nav>
      <div class="nav-logo">Flow<span>Lens</span></div>
      <div class="nav-pills">
        <span class="pill pill-cyan">Track F · Flow Scan</span>
        <span class="pill pill-purple">× Track B</span>
