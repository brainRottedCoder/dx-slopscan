    <!-- Hero -->
    <section class="hero">

      <!-- Track label -->
      <div class="track-label">
        <span class="track-dot"></span>
        DX-Ray Hackathon 2026 · Developer Flow Intelligence
      </div>

      <!-- Headline -->
      <h1 class="headline">
        X-ray your<br/>
        developer <span class="hl">flow</span>
