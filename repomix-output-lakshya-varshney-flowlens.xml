/* ═══════════════════════════════════════
   CHART.JS OVERRIDES
═══════════════════════════════════════ */
canvas {
  max-width: 100%;
}

/* ═══════════════════════════════════════
   UTILITY
═══════════════════════════════════════ */
.hidden { display: none !important; }

.fade-in {
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
