        <div class="feature-pill"><span class="icon">⚡</span> SHAP feature explanations</div>
        <div class="feature-pill"><span class="icon">🤖</span> AI-synthesised recommendations</div>
        <div class="feature-pill"><span class="icon">📊</span> Before / After simulator</div>
        <div class="feature-pill"><span class="icon">🔒</span> 100% local — no telemetry</div>
      </div>

    </section>

    <!-- Footer -->
