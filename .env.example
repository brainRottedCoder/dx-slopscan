# GitHub OAuth (Phase 2) — required at API startup
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
GITHUB_CALLBACK_URL=http://localhost:5173/auth/github/callback
FRONTEND_URL=http://localhost:5173

# Session signing — minimum 32 characters
SESSION_SECRET=change_me_to_a_random_string_at_least_32_chars

# Server
PORT=3001
NODE_ENV=development

# Storage paths
DB_PATH=./data/slop.db
MODELS_DIR=./models
SCAN_CACHE_TTL_HOURS=24
