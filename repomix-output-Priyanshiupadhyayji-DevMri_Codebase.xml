        currentChurn: results.heatmap?.hotspots[0]?.churn || 10,
        predictedChurn3Months: Math.round((results.heatmap?.hotspots[0]?.churn || 10) * 1.2),
        riskLevel: isHealthy ? "medium" : "high",
