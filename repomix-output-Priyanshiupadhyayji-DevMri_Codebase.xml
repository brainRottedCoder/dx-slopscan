        {/* Global Stats Grid */}
        <div style={{ display: 'grid', gridTemplateColumns: 'repeat(3, 1fr)', gap: 20, marginBottom: 60 }}>
          <div className="card" style={{ textAlign: 'center', borderTop: '3px solid var(--scan-cyan)' }}>
