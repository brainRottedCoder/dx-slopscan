}

.chat-input-container-premium input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 14px 18px;
  color: var(--text-primary);
  font-size: 0.9rem;
  outline: none;
}

.chat-msg-ai-premium p { margin-bottom: 12px; }
.chat-msg-ai-premium p:last-child { margin-bottom: 0; }
.chat-msg-ai-premium code {
  background: rgba(0,0,0,0.2);
  padding: 2px 6px;
