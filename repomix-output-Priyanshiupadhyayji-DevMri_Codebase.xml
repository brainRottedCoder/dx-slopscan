}

/* ═══════════════════════════════════════
   MODULE CARDS
   ═══════════════════════════════════════ */

.module-card {
  background: rgba(var(--bg-primary-rgb), 0.7);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(var(--scan-cyan-rgb), 0.06);
  border-radius: var(--radius-lg);
  padding: 24px;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
  position: relative;
  overflow: hidden;
  transform-style: preserve-3d;
}

.module-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--scan-cyan), transparent);
  opacity: 0;
  transition: opacity 0.4s ease;
}

/* 3D lift glow ring on hover */
.module-card::after {
  content: '';
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  background: linear-gradient(135deg, rgba(var(--scan-cyan-rgb), 0.2), transparent 50%, rgba(var(--scan-cyan-rgb), 0.1));
  opacity: 0;
  transition: opacity 0.4s ease;
  z-index: -1;
  pointer-events: none;
}

.module-card:hover {
  border-color: rgba(var(--scan-cyan-rgb), 0.15);
  box-shadow:
    0 12px 40px rgba(0, 0, 0, 0.15),
    0 0 0 1px rgba(var(--scan-cyan-rgb), 0.08);
  transform: translateY(-4px) scale(1.01);
}

.module-card:hover::before {
  opacity: 1;
}

.module-card:hover::after {
  opacity: 1;
}

.module-score-bar {
  height: 6px;
  background: var(--bg-secondary);
  border-radius: 3px;
  overflow: hidden;
  margin-top: 12px;
}

.module-score-fill {
  height: 100%;
  border-radius: 3px;
  transition: width 1.5s ease;
}

/* ═══════════════════════════════════════
   SCAN ANIMATION
   ═══════════════════════════════════════ */

@keyframes scanLine {
  0% { top: -2px; opacity: 0; }
  10% { opacity: 1; }
  90% { opacity: 1; }
  100% { top: calc(100% + 2px); opacity: 0; }
}

@keyframes scanPulse {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 1; }
}

@keyframes scoreCount {
  from { opacity: 0; transform: scale(0.5); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes heartbeat {
  0%, 100% { transform: scale(1); opacity: 0.5; }
  50% { transform: scale(1.3); opacity: 1; }
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes glow {
  0%, 100% { box-shadow: 0 0 20px rgba(0, 229, 255, 0.2); }
  50% { box-shadow: 0 0 40px rgba(0, 229, 255, 0.4); }
}

@keyframes mriDots {
  0%, 100% { opacity: 0.2; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); background: var(--scan-cyan); box-shadow: 0 0 10px var(--scan-cyan); }
}

@keyframes flicker {
  0%, 19.999%, 22%, 62.999%, 64%, 64.999%, 70%, 100% { opacity: 1; }
  20%, 21.999%, 63%, 63.999%, 65%, 69.999% { opacity: 0.4; }
}

.mri-matrix {
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  gap: 8px;
  padding: 20px;
  background: rgba(0, 0, 0, 0.4);
  border: 1px solid rgba(0, 229, 255, 0.1);
  border-radius: var(--radius-lg);
  position: relative;
}

.mri-dot {
  width: 100%;
  aspect-ratio: 1;
  background: rgba(0, 229, 255, 0.1);
  border-radius: 2px;
}

.mri-dot-active {
  animation: mriDots 1.5s ease-in-out infinite;
}

.mri-dot-complete {
  background: var(--health-green);
  box-shadow: 0 0 8px rgba(0, 230, 118, 0.3);
}

.mri-scanner-beam {
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: var(--scan-cyan);
  box-shadow: 0 0 20px var(--scan-cyan);
  animation: scanBeamX 4s linear infinite;
  z-index: 5;
  pointer-events: none;
}

@keyframes scanBeamX {
  0% { left: 0; }
  100% { left: 100%; }
}

.animate-fade-in {
  animation: fadeInUp 0.6s ease forwards;
}

.animate-glow {
  animation: glow 2s ease-in-out infinite;
}

/* ═══════════════════════════════════════
   SCAN SLICE
   ═══════════════════════════════════════ */

.scan-slice {
  position: relative;
  background: var(--bg-secondary);
  border: 1px solid rgba(0, 229, 255, 0.1);
  border-radius: var(--radius-md);
  padding: 20px;
  overflow: hidden;
}

.scan-slice-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--scan-cyan), transparent);
  box-shadow: 0 0 15px var(--scan-cyan), 0 0 30px rgba(0, 229, 255, 0.3);
  animation: scanLine 3s linear infinite;
  z-index: 2;
}

.scan-slice-progress {
  height: 4px;
  background: var(--bg-void);
  border-radius: 2px;
  overflow: hidden;
  margin-top: 12px;
}

.scan-slice-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--scan-cyan), var(--health-green));
  border-radius: 2px;
  transition: width 0.5s ease;
}

/* ═══════════════════════════════════════
   TERMINAL LOG
   ═══════════════════════════════════════ */

.terminal {
  background: var(--bg-void);
  border: 1px solid rgba(0, 229, 255, 0.08);
  border-radius: var(--radius-md);
  padding: 16px;
  font-family: var(--font-mono);
  font-size: 0.8rem;
  line-height: 1.8;
  color: var(--text-secondary);
  max-height: 200px;
  overflow-y: auto;
}

.terminal-line {
  display: flex;
  gap: 8px;
}

.terminal-prefix {
  color: var(--scan-cyan);
  user-select: none;
}

.terminal-success {
  color: var(--health-green);
}

.terminal-error {
  color: var(--critical-red);
}

/* ═══════════════════════════════════════
   HEARTBEAT
   ═══════════════════════════════════════ */

.heartbeat {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--scan-cyan);
  animation: heartbeat 1.5s ease-in-out infinite;
}

/* ═══════════════════════════════════════
   RECOMMENDATION CARD
   ═══════════════════════════════════════ */

.rec-card {
  background: var(--bg-secondary);
  border: 1px solid rgba(0, 229, 255, 0.06);
  border-radius: var(--radius-md);
  padding: 20px;
  transition: all var(--transition-normal);
}

.rec-card:hover {
  border-color: rgba(0, 229, 255, 0.15);
  background: var(--bg-surface);
}

.rec-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 8px;
}

.rec-cost {
  font-family: var(--font-mono);
  font-weight: 600;
  color: var(--warning-amber);
}

.rec-impact {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  color: var(--health-green);
}

/* ═══════════════════════════════════════
   CHAT
   ═══════════════════════════════════════ */

.chat-container {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-height: 400px;
  overflow-y: auto;
  padding: 16px;
}

.chat-message {
  max-width: 85%;
  padding: 12px 16px;
  border-radius: var(--radius-md);
  font-size: 0.9rem;
  line-height: 1.6;
}

.chat-user {
  align-self: flex-end;
  background: rgba(0, 229, 255, 0.1);
  border: 1px solid rgba(0, 229, 255, 0.2);
  color: var(--text-primary);
}

.chat-ai {
  align-self: flex-start;
  background: var(--bg-secondary);
  border: 1px solid rgba(0, 229, 255, 0.06);
  color: var(--text-primary);
}

.chat-input-row {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

/* ═══════════════════════════════════════
   LAYOUT
   ═══════════════════════════════════════ */

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 24px;
}

.container-narrow {
  max-width: 720px;
  margin: 0 auto;
  padding: 0 24px;
}

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.gap-4 { gap: 4px; }
.gap-8 { gap: 8px; }
.gap-12 { gap: 12px; }
.gap-16 { gap: 16px; }
.gap-24 { gap: 24px; }
.gap-32 { gap: 32px; }
.w-full { width: 100%; }
.text-center { text-align: center; }
.mt-8 { margin-top: 8px; }
.mt-16 { margin-top: 16px; }
.mt-24 { margin-top: 24px; }
.mt-32 { margin-top: 32px; }
.mt-48 { margin-top: 48px; }
.mb-8 { margin-bottom: 8px; }
.mb-16 { margin-bottom: 16px; }
.mb-24 { margin-bottom: 24px; }

.grid-2 {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20px;
}

.grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.grid-4 {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
}

@media (max-width: 768px) {
  .grid-2, .grid-3, .grid-4 {
    grid-template-columns: 1fr;
  }
  h1 { font-size: 2rem; }
  .score-number { font-size: 3rem; }
  .cost-ticker { font-size: 1.75rem; }
  .container { padding: 0 16px; }
}

/* ═══════════════════════════════════════
   FRICTION LOOP DIAGRAM
   ═══════════════════════════════════════ */

.friction-loop {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 24px;
}

.loop-node {
  background: var(--bg-surface);
  border: 1px solid rgba(0, 229, 255, 0.15);
  border-radius: var(--radius-md);
  padding: 10px 20px;
  font-size: 0.85rem;
  font-weight: 500;
  text-align: center;
  min-width: 200px;
}

.loop-node-break {
  border-color: var(--health-green);
  background: rgba(0, 230, 118, 0.08);
}

.loop-arrow {
  color: var(--scan-cyan);
  font-size: 1.2rem;
  opacity: 0.6;
  animation: scanPulse 2s ease-in-out infinite;
}

/* ═══════════════════════════════════════
   SCROLLBAR
   ═══════════════════════════════════════ */

::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: var(--bg-void);
}

::-webkit-scrollbar-thumb {
  background: var(--bg-surface);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--text-muted);
}

.custom-scrollbar::-webkit-scrollbar {
  width: 5px;
  height: 5px;
}

.custom-scrollbar::-webkit-scrollbar-track {
  background: transparent;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 10px;
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 229, 255, 0.2);
}
/* ═══════════════════════════════════════
   PRINT AS CLINICAL REPORT (PDF)
   ═══════════════════════════════════════ */

@media print {
  @page {
    margin: 20mm;
    size: A4 portrait;
  }

  html, body {
    background: white !important;
    color: #040608 !important;
    font-size: 11pt;
  }

  .grid-bg, .btn, .chat-container, .chat-input-row, .simulator-toggles, .no-print {
    display: none !important;
  }

  .card, .module-card, .scan-slice, .terminal, .rec-card {
    background: white !important;
    border: 1px solid #dee2e6 !important;
    box-shadow: none !important;
    backdrop-filter: none !important;
    color: #040608 !important;
    break-inside: avoid;
    margin-bottom: 20px !important;
  }

  h1, h2, h3, h4, .text-cyan, .text-green, .text-amber, .text-red {
    color: #040608 !important;
  }

  .cost-ticker {
    -webkit-text-fill-color: #ff1744 !important;
    color: #ff1744 !important;
    background: none !important;
  }

  .container {
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  .clinical-report-header {
    display: block !important;
    border-bottom: 4px solid #040608;
    padding-bottom: 20px;
    margin-bottom: 30px;
  }

  .clinical-report-header h1 {
    font-size: 24pt;
    text-transform: uppercase;
    letter-spacing: 2px;
  }

  .clinical-report-header p {
    font-family: var(--font-mono);
    font-size: 9pt;
    color: #666;
  }

  /* Force chart colors to be visible on white */
  .recharts-cartesian-axis-line, .recharts-cartesian-axis-tick-line {
    stroke: #666 !important;
  }
  
  .recharts-text {
    fill: #333 !important;
  }

  .badge {
    border: 1px solid #333 !important;
    color: #000 !important;
    background: #f8f9fa !important;
  }
}

.clinical-report-header {
  display: none;
}

/* ═══════════════════════════════════════
   X-RAY SKELETON EFFECT (Bonus Challenge)
   ═══════════════════════════════════════ */

.is-skeleton .card, 
.is-skeleton .module-card,
.is-skeleton .grid-3 > div {
  background: rgba(0, 30, 60, 0.4) !important;
  border-color: rgba(0, 229, 255, 0.4) !important;
  box-shadow: 0 0 15px rgba(0, 229, 255, 0.1) inset !important;
  color: #e8edf4 !important;
  animation: pulseScan 2.5s ease-in-out infinite !important;
  position: relative;
  overflow: hidden;
}

.is-skeleton .card::after,
.is-skeleton .module-card::after {
  content: '';
  position: absolute;
  top: 0; right: 0; bottom: 0; left: 0;
  transform: translateX(-100%);
  background: linear-gradient(90deg, transparent, rgba(0,229,255,0.05), transparent);
  animation: shimmer 1.5s infinite;
}

@keyframes pulseScan {
  0%, 100% { opacity: 1; filter: brightness(1); }
  50% { opacity: 0.6; filter: brightness(1.2); }
}

@keyframes shimmer {
  100% { transform: translateX(100%); }
}

.is-skeleton .recharts-surface {
  filter: hue-rotate(45deg) brightness(1.2) contrast(1.1);
}

.is-skeleton h1, .is-skeleton h2, .is-skeleton h3, .is-skeleton h4 {
  color: #00e5ff !important;
  text-shadow: 0 0 8px rgba(0, 229, 255, 0.5);
}

.is-skeleton .badge {
  background: transparent !important;
  border: 1px solid currentColor !important;
}

/* ═══════════════════════════════════════
   MRI SLICE VISUALIZATION (Feature #4)
   ═══════════════════════════════════════ */

.mri-slice-container {
  position: relative;
  width: 100%;
  height: 400px;
  background: linear-gradient(180deg, rgba(0,20,40,0.9) 0%, rgba(0,10,20,0.95) 100%);
  border: 1px solid rgba(0, 229, 255, 0.15);
  border-radius: var(--radius-lg);
  overflow: hidden;
}

.mri-slice-grid {
  position: absolute;
  inset: 0;
  background-image: 
    linear-gradient(rgba(0, 229, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 229, 255, 0.03) 1px, transparent 1px);
  background-size: 20px 20px;
}

.mri-slice-scan-line {
  position: absolute;
  left: 0;
  right: 0;
  height: 3px;
  background: linear-gradient(90deg, 
    transparent 0%, 
    var(--scan-cyan) 20%, 
    var(--scan-cyan) 80%, 
    transparent 100%);
  box-shadow: 
    0 0 20px var(--scan-cyan),
    0 0 40px var(--scan-cyan),
    0 0 60px rgba(0, 229, 255, 0.5);
  z-index: 10;
  transition: top 0.1s linear;
}

.mri-slice-folder {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border-radius: 4px;
  transition: all 0.3s ease;
  cursor: pointer;
}

.mri-slice-folder-icon {
  font-size: 1.5rem;
  margin-bottom: 4px;
  filter: drop-shadow(0 0 4px currentColor);
}

.mri-slice-folder-name {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-secondary);
  text-overflow: ellipsis;
  overflow: hidden;
  white-space: nowrap;
  max-width: 80px;
  text-align: center;
}

.mri-slice-folder.inflamed {
  animation: tissueInflammation 0.5s ease forwards;
}

.mri-slice-folder.inflamed .mri-slice-folder-icon,
.mri-slice-folder.inflamed .mri-slice-folder-name {
  color: var(--critical-red) !important;
  filter: drop-shadow(0 0 8px var(--critical-red));
}

.mri-slice-folder.scanned {
  opacity: 0.6;
}

.mri-slice-folder.scanning {
  animation: tissueScanning 1s ease-in-out infinite;
}

@keyframes tissueInflammation {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1.1); }
}

@keyframes tissueScanning {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.5) drop-shadow(0 0 10px var(--scan-cyan)); }
}

.mri-slice-legend {
  position: absolute;
  bottom: 16px;
  left: 16px;
  display: flex;
  gap: 16px;
  font-size: 0.7rem;
  color: var(--text-muted);
}

.mri-slice-legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
}

.mri-slice-legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.mri-slice-legend-dot.healthy { background: var(--health-green); }
.mri-slice-legend-dot.inflamed { background: var(--critical-red); box-shadow: 0 0 6px var(--critical-red); }
.mri-slice-legend-dot.scanning { background: var(--scan-cyan); box-shadow: 0 0 6px var(--scan-cyan); }

.mri-slice-depth-indicator {
  position: absolute;
  right: 16px;
  top: 50%;
  transform: translateY(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  font-family: var(--font-mono);
  font-size: 0.6rem;
  color: var(--text-muted);
}

.mri-slice-depth-bar {
  width: 4px;
  height: 200px;
  background: rgba(0, 229, 255, 0.1);
  border-radius: 2px;
  position: relative;
  overflow: hidden;
}

.mri-slice-depth-progress {
  position: absolute;
  bottom: 0;
  width: 100%;
  background: linear-gradient(to top, var(--scan-cyan), var(--health-green));
  border-radius: 2px;
  transition: height 0.1s linear;
}

.mri-slice-crosshair {
  position: absolute;
  pointer-events: none;
  z-index: 5;
}

.mri-slice-crosshair-h {
  position: absolute;
  left: 0;
  right: 0;
  height: 1px;
  background: rgba(0, 229, 255, 0.2);
}

.mri-slice-crosshair-v {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 1px;
  background: rgba(0, 229, 255, 0.2);
}

/* Scintillating Pulse */
.is-skeleton .card, .module-card {
  background: rgba(10, 14, 20, 0.72);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1px solid rgba(0, 229, 255, 0.15);
  border-radius: var(--radius-lg);
  padding: 24px;
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4), inset 0 0 20px rgba(0, 229, 255, 0.03);
  transition: all var(--transition-normal);
  position: relative;
  overflow: hidden;
}

.card:hover, .module-card:hover {
  border-color: rgba(0, 229, 255, 0.4);
  transform: translateY(-4px) scale(1.005);
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.6), 0 0 30px rgba(0, 229, 255, 0.1);
}

@keyframes x-ray-pulse {
  0%, 100% { border-color: rgba(0, 229, 255, 0.3); }
  50% { border-color: rgba(0, 229, 255, 0.7); }
}

/* ═══════════════════════════════════════
   INTERACTIVE WHAT-IF PIPELINE (Feature #2)
   ═══════════════════════════════════════ */

.what-if-pipeline {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 16px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: var(--radius-md);
  overflow-x: auto;
}

.pipeline-stage {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  background: var(--bg-surface);
  border: 2px solid rgba(0, 229, 255, 0.1);
  border-radius: var(--radius-md);
  cursor: grab;
  transition: all 0.3s ease;
  min-width: 100px;
  user-select: none;
}

.pipeline-stage:active {
  cursor: grabbing;
}

.pipeline-stage:hover {
  border-color: rgba(0, 229, 255, 0.3);
  transform: translateY(-2px);
}

.pipeline-stage.dragging {
  opacity: 0.5;
  transform: scale(0.95);
}

.pipeline-stage.disabled {
  opacity: 0.4;
  cursor: not-allowed;
  border-color: rgba(255, 23, 68, 0.2);
}

.pipeline-stage.disabled:hover {
  transform: none;
  border-color: rgba(255, 23, 68, 0.2);
}

.pipeline-stage-icon {
  font-size: 1.5rem;
}

.pipeline-stage-name {
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text-secondary);
  text-align: center;
}

.pipeline-stage-time {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  color: var(--scan-cyan);
}

.pipeline-arrow {
  color: var(--text-muted);
  font-size: 1.2rem;
  opacity: 0.5;
}

.pipeline-drop-zone {
  min-width: 80px;
  min-height: 80px;
  border: 2px dashed rgba(0, 229, 255, 0.2);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
}

.pipeline-drop-zone.active {
  border-color: var(--scan-cyan);
  background: rgba(0, 229, 255, 0.05);
}

.pipeline-drop-zone.over {
  border-color: var(--health-green);
  background: rgba(0, 230, 118, 0.1);
  transform: scale(1.05);
}

.savings-meter {
  position: relative;
  height: 12px;
  background: rgba(0, 0, 0, 0.3);
  border-radius: 6px;
  overflow: hidden;
}

.savings-meter-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--scan-cyan), var(--health-green));
  border-radius: 6px;
  transition: width 0.5s ease;
}

.savings-meter-glow {
  position: absolute;
  top: 0;
  right: 0;
  width: 20px;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4));
  animation: savingsGlow 1.5s ease-in-out infinite;
}

@keyframes savingsGlow {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}

.dx-score-glow {
  transition: all 0.3s ease;
}

.dx-score-glow.updating {
  animation: scorePulse 0.5s ease;
}

@keyframes scorePulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); text-shadow: 0 0 20px currentColor; }
}

/* ═══════════════════════════════════════
   AUTO-FIX PR BUTTON (Feature #1)
   ═══════════════════════════════════════ */

.generate-fix-btn {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #7c3aed, #4f46e5);
  border: none;
  color: white;
  padding: 12px 24px;
  border-radius: var(--radius-md);
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.generate-fix-btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(124, 58, 237, 0.4);
}

.generate-fix-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  transform: none;
}

.generate-fix-btn.loading::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  animation: fixBtnShimmer 1.5s infinite;
}

@keyframes fixBtnShimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.pr-created-toast {
  position: fixed;
  bottom: 32px;
  right: 32px;
  background: linear-gradient(135deg, #10b981, #059669);
  color: white;
  padding: 16px 24px;
  border-radius: var(--radius-md);
  box-shadow: 0 8px 32px rgba(16, 185, 129, 0.4);
  z-index: 1000;
  animation: slideInUp 0.3s ease;
}

@keyframes slideInUp {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* ═══════════════════════════════════════
   SURGERY THEATRE
   ═══════════════════════════════════════ */

@keyframes ecg-sweep {
  0% { stroke-dashoffset: 400; opacity: 0.4; }
  20% { opacity: 1; }
  80% { opacity: 1; }
  100% { stroke-dashoffset: 0; opacity: 0.4; }
}

.surgery-code-editor {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  color: #00e676;
  background: #040608;
  padding: 20px;
  min-height: 400px;
  max-height: 600px;
  overflow-y: auto;
  line-height: 1.8;
  border: none;
  outline: none;
  white-space: pre-wrap;
  word-break: break-all;
  position: relative;
}

.surgery-cursor {
  display: inline-block;
  width: 8px;
  height: 16px;
  background: #00e676;
  animation: scanPulse 0.8s infinite;
  margin-left: 2px;
  vertical-align: middle;
}

.surgery-panel {
  background: linear-gradient(135deg, rgba(2,4,6,0.98), rgba(10,14,20,0.95));
  backdrop-filter: blur(20px);
  border: 1px solid rgba(0, 229, 255, 0.15);
  box-shadow: 0 20px 80px rgba(0, 0, 0, 0.6);
  position: relative;
  overflow: hidden;
}

.surgery-panel::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--scan-cyan), transparent);
  animation: scanningLineVertical 4s linear infinite;
  opacity: 0.3;
  z-index: 10;
  pointer-events: none;
}

@keyframes scanningLineVertical {
  0% { transform: translateY(-100px); }
  100% { transform: translateY(1000px); }
}

.surgery-glass-card {
  background: rgba(10, 14, 20, 0.6);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.05);
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

.surgery-glass-card:hover {
  background: rgba(0, 229, 255, 0.08);
  border-color: rgba(0, 229, 255, 0.3);
  box-shadow: 0 8px 32px rgba(0, 229, 255, 0.1);
  transform: translateY(-2px);
}

.surgery-glow-text {
  color: #00e5ff;
  text-shadow: 0 0 10px rgba(0, 229, 255, 0.5);
}

.crt-scanline {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
  background-size: 100% 4px, 3px 100%;
  pointer-events: none;
  z-index: 10;
  opacity: 0.4;
}

/* ═══════════════════════════════════════
   TERMINAL (Fleet Scan)
   ═══════════════════════════════════════ */

.terminal {
  background: #040608;
  border: 1px solid #1a2332;
  border-radius: var(--radius-md);
  font-family: var(--font-mono);
  font-size: 0.75rem;
  padding: 12px 16px;
  overflow-y: auto;
  color: #8899aa;
}

.terminal-line {
  display: flex;
  gap: 8px;
  padding: 3px 0;
  line-height: 1.5;
}
/* ─── PREMIUM CLINICAL CHATBOT ─── */
.chat-window-premium {
  position: fixed;
  bottom: 100px;
  right: 24px;
  width: 420px;
  height: min(700px, 80vh);
  background: var(--card-bg);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1px solid var(--nav-border);
  border-radius: 20px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  z-index: 9998;
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), var(--shadow-glow);
  animation: chatEnter 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes chatEnter {
  from { opacity: 0; transform: translateY(30px) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.chat-header-premium {
  padding: 16px 20px;
  background: rgba(var(--bg-void-rgb), 0.5);
  border-bottom: 1px solid var(--nav-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chat-messages-premium {
  flex: 1;
  overflow-y: auto;
  padding: 24px 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  scroll-behavior: smooth;
}

.chat-msg-ai-premium {
  align-self: flex-start;
  max-width: 85%;
  background: var(--bg-secondary);
  border: 1px solid var(--nav-border);
