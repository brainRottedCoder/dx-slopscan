  const handlePipelineScoreUpdate = useCallback((boost: number, savings: number) => {
    setPipelineScoreBoost(boost);
    setPipelineSavings(savings);
    setDxScoreGlow(true);
    setTimeout(() => setDxScoreGlow(false), 500);
