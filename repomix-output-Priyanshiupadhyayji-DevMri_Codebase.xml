#!/bin/bash

# DevMRI Action - Developer Experience Scanner for GitHub
# This action scans PRs and comments with DX impact metrics

set -e

echo "🩻 DevMRI: Running Developer Experience Scan..."

# Get inputs
GITHUB_TOKEN="${{ inputs.github-token }}"
SCAN_MODE="${{ inputs.scan-mode }}"
COMMENT_PR="${{ inputs.comment-pr }}"
REPO_OWNER="${{ github.repository_owner }}"
REPO_NAME="${{ github.event.repository.name }}"
PR_NUMBER="${{ github.event.pull_request.number }}"

# Default values
DX_SCORE=75
DX_GRADE="B"
BUILD_IMPACT="+15s"
FRICTION_COST="$1,200"

# Calculate DX metrics based on PR changes
if [ "$SCAN_MODE" = "pr" ]; then
    echo "📋 Scanning PR #$PR_NUMBER for DX impact..."
    
    # Get PR files
    FILES=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO_OWNER/$REPO_NAME/pulls/$PR_NUMBER/files" | \
        jq -r '.[].filename' | wc -l)
    
    # Get PR size
    ADDITIONS=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO_OWNER/$REPO_NAME/pulls/$PR_NUMBER" | \
        jq -r '.additions')
    
    DELETIONS=$(curl -s -H "Authorization: token $GITHUB_TOKEN" \
        "https://api.github.com/repos/$REPO_OWNER/$REPO_NAME/pulls/$PR_NUMBER" | \
        jq -r '.deletions')
    
    TOTAL_CHANGES=$((ADDITIONS + DELETIONS))
    
    # Estimate DX impact
    if [ "$TOTAL_CHANGES" -gt 1000 ]; then
        DX_SCORE=55
        DX_GRADE="D"
        BUILD_IMPACT="+45s"
        FRICTION_COST="$3,200"
    elif [ "$TOTAL_CHANGES" -gt 500 ]; then
        DX_SCORE=68
        DX_GRADE="C"
        BUILD_IMPACT="+25s"
        FRICTION_COST="$1,800"
    elif [ "$TOTAL_CHANGES" -gt 200 ]; then
        DX_SCORE=75
        DX_GRADE="B"
        BUILD_IMPACT="+15s"
        FRICTION_COST="$1,200"
    else
        DX_SCORE=85
        DX_GRADE="A"
        BUILD_IMPACT="+5s"
        FRICTION_COST="$450"
    fi
    
    # Generate comment
    COMMENT_BODY="## 🩻 DevMRI DX IMPACT REPORT

### This PR Impact Summary
| Metric | Value |
|--------|-------|
| 📊 DX Score Impact | $DX_SCORE (Grade: $DX_GRADE) |
| ⏱️ Build Time Change | $BUILD_IMPACT |
| 💰 Monthly Friction Cost | \$$FRICTION_COST |
| 📝 Files Changed | $FILES |
| 📏 Lines Changed | $TOTAL_CHANGES |

### DX Health Indicators
$([ "$DX_SCORE" -lt 70 ] && echo "⚠️ **Warning**: This PR may negatively impact developer experience" || echo "✅ **Good**: This PR follows DX best practices")

### Recommendations
$([ "$TOTAL_CHANGES" -gt 500 ] && echo "- Consider breaking this PR into smaller chunks for faster reviews" || echo "- PR size is optimal for review efficiency")
$([ "$ADDITIONS" -gt 800 ] && echo "- High addition count - ensure adequate test coverage" || echo "- Code additions are well-scoped")

---
*Scanned by DevMRI Action* | [View Full Report](https://devmri.app)"

    # Post comment if enabled
    if [ "$COMMENT_PR" = "true" ]; then
        echo "💬 Posting DX impact comment..."
        curl -s -X POST \
            -H "Authorization: token $GITHUB_TOKEN" \
            -H "Accept: application/vnd.github.v3+json" \
            "https://api.github.com/repos/$REPO_OWNER/$REPO_NAME/issues/$PR_NUMBER/comments" \
            -d "{\"body\": \"$COMMENT_BODY\"}"
    fi
fi

# Set outputs
echo "::set-output name=dx-score::$DX_SCORE"
echo "::set-output name=dx-grade::$DX_GRADE"
echo "::set-output name=build-impact::$BUILD_IMPACT"
echo "::set-output name=friction-cost::$FRICTION_COST"

echo "✅ DevMRI scan complete!"
echo "📊 DX Score: $DX_SCORE (Grade: $DX_GRADE)"
echo "⏱️ Build Impact: $BUILD_IMPACT"
</file>

<file path="devmri-action/action.yml">
name: 'DevMRI DX Scanner'
description: 'Automatically scan PRs and repos with DevMRI. Comments DX Score, grade, friction cost, and AI recommendations on every PR.'
author: 'DevMRI'
branding:
  icon: activity
  color: blue

inputs:
  github-token:
    description: 'GitHub token for API access and PR commenting'
    required: true
    default: ${{ github.token }}
  gemini-api-key:
    description: 'Google Gemini API Key for AI-powered recommendations (optional)'
    required: false
  scan-mode:
    description: 'Scan mode: "pr" (comment on PR) or "full" (full repo scan)'
    default: 'pr'
  fail-threshold:
    description: 'If DX Score is below this value, the action will fail. Set to 0 to disable.'
    default: '0'
  comment-style:
    description: 'Comment style: "full" (detailed table) or "compact" (summary badge)'
    default: 'full'
  slack-webhook-url:
    description: 'Slack Incoming Webhook URL for posting DX reports (optional)'
    required: false

outputs:
  dx-score:
    description: 'The DX Score (0-100)'
    value: ${{ steps.scan.outputs.dx-score }}
  dx-grade:
    description: 'The DX Grade (A-F)'
    value: ${{ steps.scan.outputs.dx-grade }}
  friction-cost:
    description: 'Estimated monthly friction cost in USD'
    value: ${{ steps.scan.outputs.friction-cost }}

runs:
  using: composite
  steps:
    - name: Setup Node.js
      uses: actions/setup-node@v4
      with:
        node-version: '20'

    - name: Run DevMRI Scan
      id: scan
      shell: bash
      env:
        GITHUB_TOKEN: ${{ inputs.github-token }}
        GEMINI_API_KEY: ${{ inputs.gemini-api-key }}
      run: |
        echo "🩻 DevMRI: Initiating Developer Experience Scan..."
        REPO="${{ github.repository }}"
        OWNER=$(echo $REPO | cut -d'/' -f1)
        REPO_NAME=$(echo $REPO | cut -d'/' -f2)
        PR_NUMBER="${{ github.event.pull_request.number }}"
        SCAN_MODE="${{ inputs.scan-mode }}"
        THRESHOLD="${{ inputs.fail-threshold }}"

        # Install DevMRI CLI
        npm install -g devmri@latest 2>/dev/null || true

        # Run the scan and capture JSON output
        RESULT=$(npx devmri scan "$REPO" --token "$GITHUB_TOKEN" --json --no-report 2>/dev/null || echo '{}')

        # Extract values
        DX_SCORE=$(echo "$RESULT" | jq -r '.dxScore // 0')
        DX_GRADE=$(echo "$RESULT" | jq -r '.grade // "?"')
        FRICTION_COST=$(echo "$RESULT" | jq -r '.frictionCost.total // 0')
        CI_SCORE=$(echo "$RESULT" | jq -r '.scores.cicd // 0')
        REVIEW_SCORE=$(echo "$RESULT" | jq -r '.scores.reviews // 0')
        DEP_SCORE=$(echo "$RESULT" | jq -r '.scores.deps // 0')
        DOC_SCORE=$(echo "$RESULT" | jq -r '.scores.doc // 0')
        VULNS=$(echo "$RESULT" | jq -r '.deps.vulnerabilities.total // 0')
        STALE_PRS=$(echo "$RESULT" | jq -r '.reviews.stalePRs | length // 0')
        AVG_BUILD=$(echo "$RESULT" | jq -r '.cicd.avgDurationMinutes // 0')

        # Set outputs
        echo "dx-score=$DX_SCORE" >> $GITHUB_OUTPUT
        echo "dx-grade=$DX_GRADE" >> $GITHUB_OUTPUT
        echo "friction-cost=$FRICTION_COST" >> $GITHUB_OUTPUT

        # Determine score color for badge
        if [ "$DX_SCORE" -ge 80 ]; then BADGE_COLOR="brightgreen"; EMOJI="🟢";
        elif [ "$DX_SCORE" -ge 60 ]; then BADGE_COLOR="yellow"; EMOJI="🟡";
        elif [ "$DX_SCORE" -ge 40 ]; then BADGE_COLOR="orange"; EMOJI="🟠";
        else BADGE_COLOR="red"; EMOJI="🔴"; fi

        # Generate PR comment
        if [ "$SCAN_MODE" = "pr" ] && [ -n "$PR_NUMBER" ] && [ "${{ inputs.comment-style }}" != "none" ]; then
          echo "💬 Posting DX Impact Report to PR #$PR_NUMBER..."

          COMMENT_BODY=$(cat <<EOF
        ## 🩻 DevMRI — DX Impact Report

        $EMOJI **DX Score: $DX_SCORE / 100** (Grade **$DX_GRADE**)

        | Module | Score | Status |
        |--------|-------|--------|
        | ⚡ CI/CD Pipeline | $CI_SCORE | $([ "$CI_SCORE" -ge 70 ] && echo "✅ Healthy" || echo "⚠️ Needs Attention") |
        | 👀 Code Reviews | $REVIEW_SCORE | $([ "$REVIEW_SCORE" -ge 70 ] && echo "✅ Healthy" || echo "⚠️ Needs Attention") |
        | 📦 Dependencies | $DEP_SCORE | $([ "$DEP_SCORE" -ge 70 ] && echo "✅ Healthy" || echo "⚠️ Needs Attention") |
        | 📝 Documentation | $DOC_SCORE | $([ "$DOC_SCORE" -ge 70 ] && echo "✅ Healthy" || echo "⚠️ Needs Attention") |

        ### 💰 Friction Cost
        > **\$$FRICTION_COST/month** in estimated developer productivity waste

        ### Key Findings
        $([ "$VULNS" -gt 0 ] && echo "- 🛡️ **$VULNS** dependency vulnerabilities detected" || echo "- 🛡️ No vulnerabilities detected ✅")
        $([ "$STALE_PRS" -gt 3 ] && echo "- ⏰ **$STALE_PRS** stale PRs waiting >7 days" || echo "- ⏰ PR queue is healthy ✅")
        $(echo "$AVG_BUILD" | awk '{if ($1 > 10) print "- 🐢 Average build time: **" $1 "m** (consider optimization)"; else print "- ⚡ Build time: **" $1 "m** ✅"}')

        ---
        <sub>🩻 Scanned by <a href="https://github.com/urjitupadhya/DEVmri">DevMRI</a> · DX-Ray Hackathon 2026</sub>
        EOF
        )

          # Post comment via GitHub API
          ESCAPED_BODY=$(echo "$COMMENT_BODY" | jq -Rs .)
          curl -s -X POST \
            -H "Authorization: token $GITHUB_TOKEN" \
            -H "Accept: application/vnd.github.v3+json" \
            "https://api.github.com/repos/$REPO/issues/$PR_NUMBER/comments" \
            -d "{\"body\": $ESCAPED_BODY}" > /dev/null

          echo "✅ DX Impact Report posted to PR #$PR_NUMBER"
        fi

        # Threshold check
        if [ "$THRESHOLD" -gt 0 ] && [ "$DX_SCORE" -lt "$THRESHOLD" ]; then
          echo "❌ DX Score ($DX_SCORE) is below threshold ($THRESHOLD). Failing the check."
          exit 1
        fi

        echo "✅ DevMRI scan complete — DX Score: $DX_SCORE (Grade $DX_GRADE)"

    - name: Notify Slack
      if: always() && inputs.slack-webhook-url != ''
      shell: bash
      env:
        SLACK_WEBHOOK: ${{ inputs.slack-webhook-url }}
        DX_SCORE: ${{ steps.scan.outputs.dx-score }}
        DX_GRADE: ${{ steps.scan.outputs.dx-grade }}
        FRICTION_COST: ${{ steps.scan.outputs.friction-cost }}
      run: |
        GRADE_EMOJI=$( [ "$DX_GRADE" = "A" ] && echo "🟢" || [ "$DX_GRADE" = "B" ] && echo "🔵" || [ "$DX_GRADE" = "C" ] && echo "🟡" || [ "$DX_GRADE" = "D" ] && echo "🟠" || echo "🔴" )
        curl -s -X POST "$SLACK_WEBHOOK" \
          -H "Content-Type: application/json" \
          -d "{\"blocks\":[{\"type\":\"header\",\"text\":{\"type\":\"plain_text\",\"text\":\"DevMRI DX Report — ${{ github.repository }}\",\"emoji\":true}},{\"type\":\"divider\"},{\"type\":\"section\",\"fields\":[{\"type\":\"mrkdwn\",\"text\":\"*DX Score*\n${GRADE_EMOJI} *${DX_SCORE}* / 100 (Grade *${DX_GRADE}*)\"},{\"type\":\"mrkdwn\",\"text\":\"*Friction Cost*\n💰 *\$${FRICTION_COST}/mo*\"}]},{\"type\":\"context\",\"elements\":[{\"type\":\"mrkdwn\",\"text\":\"Scanned by DevMRI Action\"}]}]}"
</file>

<file path="devmri-action/README.md">
# DevMRI GitHub Action

Automatically scan pull requests and comment with Developer Experience (DX) impact metrics.

## Features

- **DX Score Calculation**: Analyzes PR size and complexity to calculate a DX impact score
- **Build Time Estimation**: Estimates how this PR will affect CI/CD build times  
- **Friction Cost Analysis**: Calculates monthly developer friction cost impact
- **Automatic Comments**: Posts DX impact report directly on PRs

## Usage

```yaml
name: DevMRI DX Scanner

on:
  pull_request:
    types: [opened, synchronize]

jobs:
  devmri:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Run DevMRI DX Scan
        uses: your-org/devmri-action@v1
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          scan-mode: 'pr'
          comment-pr: 'true'
```

## Inputs

| Input | Required | Default | Description |
|-------|----------|---------|-------------|
| `github-token` | Yes | - | GitHub token for API access |
| `scan-mode` | No | `pr` | Scan mode: `pr`, `full`, or `quick` |
| `comment-pr` | No | `true` | Whether to comment on PR with DX impact |

## Outputs

| Output | Description |
|--------|-------------|
| `dx-score` | DX Score (0-100) |
| `dx-grade` | DX Grade (A-F) |
| `build-impact` | Estimated build time change |
| `friction-cost` | Estimated monthly friction cost |

## Example PR Comment

When enabled, the action will post a comment like:

> ## 🩻 DevMRI DX IMPACT REPORT
> 
> ### This PR Impact Summary
> | Metric | Value |
> |--------|-------|
> | 📊 DX Score Impact | 75 (Grade: B) |
> | ⏱️ Build Time Change | +15s |
> | 💰 Monthly Friction Cost | $1,200 |
> 
> ### DX Health Indicators
> ✅ **Good**: This PR follows DX best practices
> 
> ---
> *Scanned by DevMRI Action* | [View Full Report](https://devmri.app)

## License

MIT
