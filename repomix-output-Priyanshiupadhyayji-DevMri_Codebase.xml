}

.terminal-prefix {
  color: #00e676;
  user-select: none;
  flex-shrink: 0;
}

/* ═══════════════════════════════════════
   X-RAY DEEP ZOOM
   ═══════════════════════════════════════ */

.deep-zoom-file {
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.deep-zoom-file:hover {
  transform: scale(1.08);
  z-index: 10;
}

.deep-zoom-file::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  transition: opacity 0.3s;
  opacity: 0;
}

.deep-zoom-file:hover::after {
  opacity: 1;
}

@keyframes radiation-pulse {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.3); opacity: 0; }
}

.radiation-ring {
  position: absolute;
  inset: -10px;
  border-radius: 50%;
  border: 1px solid rgba(255,23,68,0.3);
  animation: radiation-pulse 2s ease-in-out infinite;
  pointer-events: none;
}

.bleeding-dot {
  position: absolute;
  top: 4px;
  right: 4px;
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ff1744;
  box-shadow: 0 0 8px #ff1744, 0 0 16px rgba(255,23,68,0.3);
  animation: heartbeat 1s infinite;
}

/* ═══════════════════════════════════════
   FLEET SCAN / ORG PAGE
   ═══════════════════════════════════════ */

.fleet-row {
  transition: background 0.2s ease;
}

.fleet-row:hover {
  background: rgba(0, 229, 255, 0.03);
}

.floating-chat-btn {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, rgba(0,229,255,0.15), rgba(10,14,20,0.92) 70%);
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  box-shadow: 0 8px 40px rgba(0,229,255,0.35), 0 0 0 2px rgba(0,229,255,0.15);
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.18, 0.89, 0.32, 1.28);
  position: relative;
  z-index: 10;
}

.floating-chat-btn:hover {
  transform: scale(1.12);
  box-shadow: 0 14px 56px rgba(0,229,255,0.5), 0 0 0 3px rgba(0,229,255,0.25);
}

.floating-chat-btn:active {
  transform: scale(0.95);
  transition-duration: 0.1s;
}

.floating-chat-btn.active {
  background: rgba(10,14,20,0.95);
  color: #00e5ff;
  border: 1.5px solid rgba(0,229,255,0.3);
  box-shadow: 0 0 30px rgba(0,0,0,0.4), inset 0 0 20px rgba(0,229,255,0.05);
}

/* 3D Mascot animations */
@keyframes pulseRing {
  0%, 100% { transform: scale(1); opacity: 0.3; }
  50% { transform: scale(1.15); opacity: 0.7; }
}

@keyframes mascotFloat {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-3px) scale(1.03); }
}

.fleet-health-bar {
  display: flex;
  height: 20px;
  border-radius: 10px;
  overflow: hidden;
  gap: 2px;
}

.fleet-health-bar > div {
  transition: flex 1s ease;
}

/* Friction Debt Counter Animation */
@keyframes countUp {
  from { opacity: 0; transform: translateY(10px); }
  to { opacity: 1; transform: translateY(0); }
}

.friction-debt-number {
  animation: countUp 0.5s ease-out;
  font-family: var(--font-mono);
}

/* Badge Copy Button */
.badge-copy-btn {
  position: absolute;
  top: 8px;
  right: 8px;
  background: #1a2332;
  color: #00e5ff;
  border: none;
  border-radius: 6px;
  padding: 4px 10px;
  font-size: 0.7rem;
  cursor: pointer;
  font-weight: 600;
  transition: all 0.2s;
}

.badge-copy-btn:hover {
  background: #00e5ff;
  color: #000;
}

.badge-copy-btn.copied {
  background: #00e676;
  color: #000;
}

/* ═══════════════════════════════════════
   MODERN CHAT UX
   ═══════════════════════════════════════ */

.chat-bubble-container {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16px;
}

.chat-window {
  width: 400px;
  height: 600px;
  background: #0a0e14;
  border: 1px solid rgba(0, 229, 255, 0.15);
  border-radius: 20px;
  box-shadow: 0 12px 48px rgba(0, 0, 0, 0.6), 0 0 20px rgba(0, 229, 255, 0.05);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  backdrop-filter: blur(20px);
  animation: chatSlideIn 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
}

@keyframes chatSlideIn {
  from { opacity: 0; transform: translateY(40px) scale(0.9); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

.chat-header {
  padding: 16px 20px;
  background: linear-gradient(90deg, #0a0e14, #121822);
  border-bottom: 1px solid rgba(0, 229, 255, 0.1);
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 16px;
  scrollbar-width: thin;
  scrollbar-color: rgba(0, 229, 255, 0.1) transparent;
}

.chat-message {
  max-width: 85%;
  padding: 12px 16px;
  border-radius: 12px;
  font-size: 0.9rem;
  line-height: 1.5;
}

.chat-message.user {
  align-self: flex-end;
  background: #00e5ff22;
  border: 1px solid #00e5ff33;
  color: #e8edf4;
  border-bottom-right-radius: 2px;
}

.chat-message.ai {
  align-self: flex-start;
  background: #111822;
  border: 1px solid #1a2332;
  color: #8899aa;
  border-bottom-left-radius: 2px;
}

.chat-message.ai a { color: #00e5ff; text-decoration: underline; }
.chat-message.ai code { background: #000; padding: 2px 4px; border-radius: 4px; color: #00e676; }
.chat-message.ai pre { background: #000; padding: 12px; border-radius: 8px; margin: 8px 0; overflow-x: auto; }
.chat-message.ai table { width: 100%; border-collapse: collapse; margin: 8px 0; font-size: 0.8rem; }
.chat-message.ai th, .chat-message.ai td { border: 1px solid #1a2332; padding: 6px; text-align: left; }

.suggestion-chips {
  padding: 0 20px 12px;
  display: flex;
  gap: 8px;
  overflow-x: auto;
  scrollbar-width: none;
}

.suggestion-chip {
  flex-shrink: 0;
  background: rgba(0, 229, 255, 0.05);
  border: 1px solid rgba(0, 229, 255, 0.1);
  border-radius: 20px;
  padding: 6px 12px;
  font-size: 0.75rem;
  color: #00e5ff;
  cursor: pointer;
  transition: all 0.2s;
  white-space: nowrap;
}

.suggestion-chip:hover {
  background: rgba(0, 229, 255, 0.1);
  border-color: #00e5ff;
}

.chat-input-area {
  padding: 16px 20px;
  background: #040608;
  border-top: 1px solid rgba(0, 229, 255, 0.1);
}

.chat-input-container {
  display: flex;
  background: #0a0e14;
  border: 1px solid #1a2332;
  border-radius: 12px;
  overflow: hidden;
  transition: border-color 0.2s;
}

.chat-input-container:focus-within {
  border-color: #00e5ff;
}

.chat-input-container input {
  flex: 1;
  background: transparent;
  border: none;
  padding: 12px 16px;
  color: #e8edf4;
  outline: none;
}

.floating-chat-btn {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: linear-gradient(135deg, #00e5ff, #0091ea);
  color: #000;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  box-shadow: 0 8px 32px rgba(0, 229, 255, 0.3);
  cursor: pointer;
  transition: transform 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28), box-shadow 0.3s;
}

.floating-chat-btn:hover {
  transform: scale(1.1) rotate(5deg);
  box-shadow: 0 12px 48px rgba(0, 229, 255, 0.5);
}

.floating-chat-btn.active {
  background: #121822;
  color: #00e5ff;
  border: 1px solid #1a2332;
}

/* ═══════════════════════════════════════
   CINEMATIC SCORE REVEAL ANIMATIONS
   ═══════════════════════════════════════ */

@keyframes xraySweep {
  0% {
    clip-path: inset(0 0 100% 0);
  }
  100% {
    clip-path: inset(0 0 0% 0);
  }
}

@keyframes scoreRevealBlur {
  0% {
    filter: blur(20px);
    opacity: 0;
    transform: scale(1.5);
  }
  100% {
    filter: blur(0);
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes scoreBounce {
  0% {
    transform: scale(0);
  }
  50% {
    transform: scale(1.2);
  }
  70% {
    transform: scale(0.9);
  }
  100% {
    transform: scale(1);
  }
}

@keyframes gradeDropIn {
  0% {
    opacity: 0;
    transform: translateY(-50px) scale(2);
  }
  60% {
    opacity: 1;
    transform: translateY(10px) scale(0.9);
  }
  80% {
    transform: translateY(-5px) scale(1.05);
  }
  100% {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes scoreGlowPulse {
  0%, 100% {
    box-shadow: 0 0 30px var(--score-glow-color, rgba(0, 229, 255, 0.5));
  }
  50% {
    box-shadow: 0 0 60px var(--score-glow-color, rgba(0, 229, 255, 0.8)), 0 0 100px var(--score-glow-color, rgba(0, 229, 255, 0.3));
  }
}

@keyframes cinematicFadeIn {
  0% {
    opacity: 0;
  }
  100% {
    opacity: 1;
  }
}

@keyframes xrayLineSweep {
  0% {
    transform: translateY(-100%);
  }
  100% {
    transform: translateY(100vh);
  }
}

.cinematic-score-container {
  --score-glow-color: #00e5ff;
  position: relative;
  overflow: hidden;
}

.cinematic-score-container::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 229, 255, 0.1) 50%, transparent 100%);
  animation: xrayLineSweep 2s ease-in-out infinite;
  pointer-events: none;
  z-index: 10;
}

.cinematic-xray-effect {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 229, 255, 0.15) 50%, transparent 100%);
  animation: xraySweep 1.5s ease-in-out forwards;
  pointer-events: none;
}

.cinematic-score-blur {
  animation: scoreRevealBlur 1s ease-out forwards;
}

.cinematic-score-value {
  animation: scoreBounce 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
}

.cinematic-grade {
  animation: gradeDropIn 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55) forwards;
}

.cinematic-glow {
  animation: scoreGlowPulse 2s ease-in-out infinite;
}

.cinematic-overlay {
  position: fixed;
  inset: 0;
  background: radial-gradient(circle at center, transparent 0%, rgba(0, 0, 0, 0.8) 100%);
  animation: cinematicFadeIn 0.5s ease forwards;
  pointer-events: none;
  z-index: 100;
}

/* ═══════════════════════════════════════
   MOBILE RESPONSIVE FIXES
   ═══════════════════════════════════════ */

.tabs-container::-webkit-scrollbar {
  display: none;
}

@media (max-width: 768px) {
  .tabs-container {
    flex-wrap: nowrap !important;
    padding: 8px 0;
    margin: 0 -24px;
    padding-left: 24px;
    padding-right: 24px;
  }
  
  .tabs-container .btn {
    flex-shrink: 0;
    font-size: 0.7rem !important;
    padding: 6px 10px !important;
    white-space: nowrap;
  }
  
  .chat-bubble-container {
    bottom: 16px;
    right: 16px;
    gap: 8px;
  }
  
  .chat-window {
    width: calc(100vw - 80px) !important;
    max-width: 320px !important;
    height: 400px !important;
  }
  
  .grid-2 {
    grid-template-columns: 1fr !important;
  }
  
  .grid-3 {
    grid-template-columns: 1fr !important;
  }
  
  .container {
    padding: 16px !important;
  }
  
  .score-reveal {
    padding: 8px 16px !important;
  }
  
  .score-reveal > div:first-child {
    font-size: 1.5rem !important;
  }
}

@media (max-width: 480px) {
  .tabs-container .btn {
    font-size: 0.65rem !important;
    padding: 5px 8px !important;
  }
  
  .chat-bubble-container {
    bottom: 12px;
    right: 12px;
  }
  
  .chat-window {
    width: calc(100vw - 40px) !important;
    max-width: 280px !important;
    height: 350px !important;
  }
}


/* ═══════════════════════════════════════
   REAL-TIME EKG HEARTBEAT VISUALIZER
   ═══════════════════════════════════════ */

@keyframes ekg-line-draw {
  0% {
    stroke-dashoffset: 1000;
  }
  100% {
    stroke-dashoffset: 0;
  }
}

@keyframes ekg-pulse-glow {
  0%, 100% {
    filter: drop-shadow(0 0 2px currentColor);
  }
  50% {
    filter: drop-shadow(0 0 8px currentColor) drop-shadow(0 0 12px currentColor);
  }
}

.ekg-canvas {
  background: linear-gradient(180deg, #0a0e14 0%, #0d1218 100%);
  border-radius: 12px;
  border: 1px solid rgba(0, 229, 255, 0.1);
}

.ekg-grid {
  stroke: rgba(0, 229, 255, 0.05);
  stroke-width: 1;
}

.ekg-line {
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
  filter: drop-shadow(0 0 4px currentColor);
}

.ekg-line.critical {
  stroke: #ff1744;
  animation: ekg-pulse-glow 0.5s ease-in-out infinite;
}

.ekg-line.warning {
  stroke: #ff6d00;
  animation: ekg-pulse-glow 0.75s ease-in-out infinite;
}

.ekg-line.healthy {
  stroke: #00e676;
  animation: ekg-pulse-glow 1s ease-in-out infinite;
}

.ekg-line.idle {
  stroke: #334455;
  stroke-width: 1;
}

.ekg-monitor {
  background: linear-gradient(180deg, #0a0e14 0%, #040608 100%);
  border-radius: 16px;
  border: 2px solid rgba(0, 229, 255, 0.2);
  box-shadow: 0 0 20px rgba(0, 229, 255, 0.1), inset 0 0 40px rgba(0, 0, 0, 0.5);
}

.ekg-monitor-screen {
  background: linear-gradient(180deg, #0a0e14 0%, #07100a 100%);
  border-radius: 8px;
  position: relative;
  overflow: hidden;
}

.ekg-monitor-screen::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(90deg, transparent 0%, rgba(0, 229, 255, 0.03) 50%, transparent 100%);
  animation: ekg-scanline 2s linear infinite;
  pointer-events: none;
}

@keyframes ekg-scanline {
  0% {
    transform: translateX(-100%);
  }
  100% {
    transform: translateX(100%);
  }
}

.ekg-readout {
  font-family: 'JetBrains Mono', monospace;
  font-variant-numeric: tabular-nums;
}

.ekg-bpm-display {
  text-shadow: 0 0 10px currentColor;
}

.ekg-heart-icon {
  animation: ekg-heartbeat 1s ease-in-out infinite;
}

@keyframes ekg-heartbeat {
  0%, 100% {
    transform: scale(1);
  }
  15% {
    transform: scale(1.2);
  }
  30% {
    transform: scale(1);
  }
}

/* ═══════════════════════════════════════
   DOCUMENTATION PAGE STYLES
   ═══════════════════════════════════════ */

.docs-container {
  max-width: 1000px;
  margin: 0 auto;
  padding: 80px 24px;
}

.docs-hero {
  text-align: center;
  margin-bottom: 80px;
}

.docs-subtitle {
  color: #00e5ff;
  font-family: var(--font-mono);
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  margin-bottom: 12px;
  font-size: 0.9rem;
}

.docs-title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 900;
  margin-bottom: 24px;
  background: linear-gradient(to bottom, #fff, #8899aa);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
  line-height: 1.1;
}

.docs-desc {
  font-size: 1.1rem;
  color: #8899aa;
  max-width: 650px;
  margin: 0 auto;
  line-height: 1.6;
}

.docs-section {
  margin-bottom: 100px;
}

.docs-section-title {
  font-size: 1.8rem;
  font-weight: 800;
  margin-bottom: 40px;
  display: flex;
  align-items: center;
  gap: 16px;
}

.docs-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 24px;
}

.docs-module-card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 20px;
  padding: 32px;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.docs-module-card:hover {
  transform: translateY(-8px);
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(0, 229, 255, 0.3);
  box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4), 0 0 20px rgba(0, 229, 255, 0.1);
}

.docs-module-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  width: 4px;
  height: 100%;
  background: var(--accent);
  opacity: 0;
  transition: opacity 0.3s;
}

.docs-module-card:hover::before {
  opacity: 1;
}

.docs-card-icon {
  font-size: 2.5rem;
  margin-bottom: 20px;
  display: block;
}

.docs-card-title {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 12px;
  color: #e8edf4;
}

.docs-card-text {
  color: #8899aa;
  font-size: 0.95rem;
  line-height: 1.6;
}

.docs-quote {
  padding: 40px;
  border-radius: 24px;
  background: linear-gradient(135deg, rgba(0, 229, 255, 0.1), transparent);
  border: 1px solid rgba(0, 229, 255, 0.2);
  text-align: center;
  margin: 60px 0;
}

.docs-quote p {
  font-size: 1.4rem;
  font-weight: 500;
  font-style: italic;
  color: #e8edf4;
  margin-bottom: 16px;
}

.docs-quote cite {
  font-size: 0.9rem;
  color: #00e5ff;
  font-family: var(--font-mono);
  text-transform: uppercase;
}

.docs-clinical-note {
  font-size: 0.8rem;
  color: #556677;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-top: 16px;
  display: block;
}

.docs-cta-banner {
  margin-top: 120px;
  padding: 60px;
  text-align: center;
  background: radial-gradient(circle at center, rgba(0, 229, 255, 0.15) 0%, transparent 70%);
  border-radius: 32px;
  border: 1px solid rgba(0, 229, 255, 0.1);
}

.docs-step {
  display: flex;
  gap: 32px;
  margin-bottom: 48px;
  align-items: flex-start;
}

.docs-step-number {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(0, 229, 255, 0.1);
  border: 2px solid #00e5ff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-mono);
  font-weight: 900;
  color: #00e5ff;
  flex-shrink: 0;
}

@media (max-width: 768px) {
  .docs-grid {
    grid-template-columns: 1fr;
  }
}



/* ─── SMOOTH TICKER ANIMATION ─── */
@keyframes ticker-scroll {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

.ticker-content {
  display: inline-block;
  white-space: nowrap;
  animation: ticker-scroll 60s linear infinite;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: #556677;
}

.ticker-content:hover {
  animation-play-state: paused;
}

/* ═══════════════════════════════════════
   CODEBASE AUTOPSY TERMINAL
   ═══════════════════════════════════════ */

.autopsy-terminal {
  background: linear-gradient(180deg, #0a0e14 0%, #050810 100%) !important;
  border: 1px solid rgba(0, 229, 255, 0.1) !important;
  font-family: 'JetBrains Mono', 'Fira Code', monospace !important;
}

.autopsy-terminal .terminal-line {
  padding: 2px 0;
  font-size: 0.75rem;
  animation: terminal-fade-in 0.3s ease forwards;
}

@keyframes terminal-fade-in {
  from {
    opacity: 0;
    transform: translateX(-10px);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.autopsy-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 16px;
  background: rgba(0, 229, 255, 0.05);
  border-bottom: 1px solid rgba(0, 229, 255, 0.1);
  margin-bottom: 12px;
}

.autopsy-header-title {
  font-size: 0.8rem;
  font-weight: 600;
  color: #00e5ff;
  text-transform: uppercase;
  letter-spacing: 2px;
}

.autopsy-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  animation: autopsy-pulse 1.5s ease-in-out infinite;
}

.autopsy-dot.success { background: #00e676; }
.autopsy-dot.warning { background: #ffab00; }
.autopsy-dot.critical { background: #ff1744; }

@keyframes autopsy-pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

/* ═══════════════════════════════════════
   MEDICAL CERTIFICATE STYLES
   ═══════════════════════════════════════ */

.medical-certificate {
  background: linear-gradient(135deg, #0a0e14 0%, #0d1520 50%, #0a0e14 100%);
  border: 2px solid rgba(0, 229, 255, 0.2);
  border-radius: 16px;
  padding: 40px;
  max-width: 600px;
  position: relative;
  overflow: hidden;
}

.medical-certificate::before {
  content: '';
  position: absolute;
  inset: 0;
  background: 
    repeating-linear-gradient(
      45deg,
      transparent,
      transparent 10px,
      rgba(0, 229, 255, 0.02) 10px,
      rgba(0, 229, 255, 0.02) 20px
    );
  pointer-events: none;
}

.medical-certificate-seal {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, #00e5ff, #00e676);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
  margin: 0 auto 20px;
  box-shadow: 0 0 30px rgba(0, 229, 255, 0.4);
}

.medical-certificate-grade {
  font-size: 6rem;
  font-weight: 900;
  line-height: 1;
}

.medical-certificate-score {
  font-size: 2.5rem;
  font-weight: 700;
}

/* ---------------------------------------
   X-RAY VISION HOVER EFFECT
   --------------------------------------- */

.xray-card {
  position: relative;
  transition: all 0.4s ease;
  cursor: pointer;
}

.xray-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, transparent 0%, rgba(0, 229, 255, 0.05) 100%);
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  border-radius: inherit;
}

.xray-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 32px rgba(0, 229, 255, 0.15);
}

.xray-card:hover::before {
  opacity: 1;
}

.xray-ghost {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.4s ease;
  pointer-events: none;
  background: rgba(0, 0, 0, 0.6);
  border-radius: inherit;
}

.xray-card:hover .xray-ghost {
  opacity: 1;
}

.xray-ghost-content {
  text-align: center;
  padding: 20px;
}

.xray-ghost-label {
  font-size: 0.7rem;
  color: #00e5ff;
  text-transform: uppercase;
  letter-spacing: 2px;
  margin-bottom: 8px;
}

.xray-ghost-value {
  font-family: 'JetBrains Mono', monospace;
  font-size: 1.5rem;
  color: #00e5ff;
  text-shadow: 0 0 10px #00e5ff;
}

/* ---------------------------------------
   \ \\THE NIGHT SHIFT\\\ (X-RAY VISION MODE)
   --------------------------------------- */

.xray-mode-active {
  --bg-primary: #000508 !important;
  --bg-secondary: #000c14 !important;
  --text-primary: #00e5ff !important;
  --text-secondary: #00e676 !important;
  --border-color: rgba(0, 229, 255, 0.3) !important;
  --card-shadow: 0 8px 32px rgba(0, 229, 255, 0.1) !important;
  --scan-cyan-dim: rgba(0, 229, 255, 0.05) !important;
}

.theme-transition {
  transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

/* --- Comparative Metrics Enhancement --- */
.metric-lead-pill {
  font-size: 0.65rem;
  padding: 2px 8px;
  border-radius: 4px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.winner-side {
  border-left: 3px solid var(--scan-cyan);
  background: linear-gradient(90deg, rgba(0,229,255,0.05) 0%, transparent 100%);
}

.loser-side {
  opacity: 0.6;
}

/* --- Dashboard Lock & UI Polish --- */
.v-lock {
  height: 100vh;
  overflow: hidden;
}

.sidebar-scroll {
  max-height: calc(100vh - 200px);
  overflow-y: auto;
}

.screen-locked .surgery-panel {
  padding: 12px !important;
}

.screen-locked p {
  font-size: 0.85rem !important;
}

/* --- PR Created Toast --- */
.pr-created-toast {
  position: fixed;
  bottom: 24px;
  right: 24px;
  width: 320px;
  background: var(--bg-void);
  border: 4px solid var(--scan-cyan);
  border-radius: 16px;
  padding: 24px;
  z-index: 5000;
  box-shadow: 0 10px 40px rgba(0,229,255,0.4), inset 0 0 20px rgba(0,229,255,0.1);
  color: #fff;
  animation: slideInRight 0.5s cubic-bezier(0.19, 1, 0.22, 1) forwards;
}

@keyframes slideInRight {
  from { transform: translateX(120%); opacity: 0; }
  to { transform: translateX(0); opacity: 1; }
}

/* --- Duel UI Enhancement --- */
.duel-vs-line {
  height: 2px;
  background: linear-gradient(90deg, var(--scan-cyan), var(--critical-red));
  margin: 12px 0;
  position: relative;
}

.duel-vs-circle {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: var(--bg-primary);
  border: 2px solid var(--border-subtle);
  padding: 2px 8px;
  border-radius: 10px;
  font-size: 0.65rem;
  font-weight: 950;
  color: var(--text-muted);
}

/* ═══════════════════════════════════════
   LOADING SKELETON SHIMMER
   ═══════════════════════════════════════ */
.skeleton {
  background: linear-gradient(
    90deg,
    rgba(var(--scan-cyan-rgb, 0, 229, 255), 0.04) 0%,
    rgba(var(--scan-cyan-rgb, 0, 229, 255), 0.08) 50%,
    rgba(var(--scan-cyan-rgb, 0, 229, 255), 0.04) 100%
  );
  background-size: 200% 100%;
  animation: shimmer 1.8s infinite ease-in-out;
  border-radius: 8px;
}

.skeleton-text {
  height: 14px;
  margin-bottom: 8px;
  border-radius: 4px;
}

.skeleton-circle {
  border-radius: 50%;
}

.skeleton-card {
  height: 120px;
  border-radius: var(--radius-md);
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ═══════════════════════════════════════
   TOAST SLIDE-UP
   ═══════════════════════════════════════ */
@keyframes slideUp {
  from { transform: translateY(40px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

/* ═══════════════════════════════════════
   CONTRIBUTOR BADGES
   ═══════════════════════════════════════ */
.contributor-avatar {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 2px solid var(--bg-void);
  box-shadow: 0 0 8px rgba(0,0,0,0.4);
  transition: transform 0.2s, box-shadow 0.2s;
}
.contributor-avatar:hover {
  transform: scale(1.3);
  box-shadow: 0 0 16px rgba(0,229,255,0.4);
  z-index: 10;
}

.contributor-stack {
  display: flex;
}
.contributor-stack .contributor-avatar + .contributor-avatar {
  margin-left: -10px;
}

/* 🩺 CLINICAL LAB ENHANCEMENTS */

/* CRT/MRI Monitor Scanline effect on the main scan results container */
.scan-monitor-overlay {
  position: relative;
  overflow: hidden;
}

.scan-monitor-overlay::after {
  content: " ";
  display: block;
  position: absolute;
  top: 0;
  left: 0;
  bottom: 0;
  right: 0;
  background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.25) 50%), linear-gradient(90deg, rgba(255, 0, 0, 0.06), rgba(0, 255, 0, 0.02), rgba(0, 0, 150, 0.06));
  z-index: 1000;
  background-size: 100% 2px, 3px 100%;
  pointer-events: none;
  opacity: 0.15;
}

/* EKG Style Pulse for the DX Score */
@keyframes heart-pulse {
  0% { transform: scale(1); filter: brightness(1) drop-shadow(0 0 10px rgba(0,229,255,0.4)); }
  5% { transform: scale(1.05); filter: brightness(1.2) drop-shadow(0 0 20px rgba(0,229,255,0.6)); }
  10% { transform: scale(1); filter: brightness(1) drop-shadow(0 0 10px rgba(0,229,255,0.4)); }
  15% { transform: scale(1.03); filter: brightness(1.1) drop-shadow(0 0 15px rgba(0,229,255,0.5)); }
  25% { transform: scale(1); filter: brightness(1) drop-shadow(0 0 10px rgba(0,229,255,0.4)); }
  100% { transform: scale(1); filter: brightness(1) drop-shadow(0 0 10px rgba(0,229,255,0.4)); }
}

.ekg-score-pulse {
  animation: heart-pulse 2.5s infinite cubic-bezier(0.1, 0, 0, 1);
}

/* Digital Microscope Effect for hotspots */
.microscope-tile {
  background: var(--card-bg);
  border: 1px solid var(--border-subtle);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.microscope-tile:hover {
  transform: scale(1.02);
  border-color: var(--scan-cyan);
  background: rgba(0, 229, 255, 0.03);
  box-shadow: 0 8px 32px rgba(0, 229, 255, 0.15);
  z-index: 1;
}

.microscope-tile::before {
  content: "";
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  background: radial-gradient(circle at center, transparent 30%, rgba(0,0,0,0.2) 100%);
  opacity: 0;
  transition: opacity 0.3s;
  pointer-events: none;
}

.microscope-tile:hover::before {
  opacity: 1;
}

/* Floating Clinical Badge */
.clinical-badge {
  background: rgba(255,255,255,0.05);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.1);
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 0.6rem;
  font-weight: 800;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-muted);
}

/* Surgery Beam effect */
.surgery-beam {
  position: relative;
}

.surgery-beam::after {
  content: '';
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 2px;
  background: linear-gradient(90deg, transparent, var(--scan-cyan), transparent);
  animation: beam-scan 4s infinite ease-in-out;
  opacity: 0.6;
}

@keyframes beam-scan {
  0% { top: 0; }
  50% { top: 100%; }
  100% { top: 0; }
}

/* Team X-Ray Enhancements */
.pulse-alert {
  animation: alert-pulse 2s infinite ease-in-out;
}

@keyframes alert-pulse {
  0%, 100% { border-color: rgba(255, 23, 68, 0.2); }
  50% { border-color: rgba(255, 23, 68, 0.6); box-shadow: 0 0 20px rgba(255, 23, 68, 0.2); }
}

.contributor-card:hover {
  background: rgba(255, 255, 255, 0.04) !important;
  border-color: var(--scan-cyan) !important;
  transform: translateX(4px);
}

.pulse-glow {
  animation: pulse-glow-anim 2s infinite ease-in-out;
}

@keyframes pulse-glow-anim {
  0%, 100% { box-shadow: 0 0 10px rgba(0, 229, 255, 0.2); }
  50% { box-shadow: 0 0 25px rgba(0, 229, 255, 0.4); }
}
/* ═══════════════════════════════════════
   CLINICAL SCROLLBARS
   ═══════════════════════════════════════ */

.custom-scrollbar::-webkit-scrollbar {
  width: 6px;
}

.custom-scrollbar::-webkit-scrollbar-track {
  background: rgba(0, 0, 0, 0.2);
  border-radius: 10px;
}

.custom-scrollbar::-webkit-scrollbar-thumb {
  background: rgba(0, 229, 255, 0.15);
  border-radius: 10px;
  border: 1px solid rgba(0, 229, 255, 0.05);
}

.custom-scrollbar::-webkit-scrollbar-thumb:hover {
  background: rgba(0, 229, 255, 0.3);
}

.scroll-area {
  max-height: 550px;
  overflow-y: auto;
  padding-right: 8px;
}

@media (max-height: 800px) {
  .scroll-area {
    max-height: 400px;
  }
}
/* ═══════════════════════════════════════
   PREMIUM CHAT INTERFACE
   ═══════════════════════════════════════ */

.chat-bubble-container {
  position: fixed;
  bottom: 24px;
  right: 24px;
  z-index: 1000;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 16px;
}

.chat-window-premium {
