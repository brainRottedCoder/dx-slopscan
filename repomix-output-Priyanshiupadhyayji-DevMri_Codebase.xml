      factors: [
        { name: "CI/CD Reliability", impact: isHealthy ? "positive" : "negative" },
        { name: "Code Review Depth", impact: "neutral" }
      ],
      riskLevel: isHealthy ? "low" : "medium",
      recommendation: isHealthy ? "Maintain current pace." : "Strengthen review process."
    },
